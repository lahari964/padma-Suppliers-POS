                  toast.success("Repair SQL copied!");
                }}>Copy Repair SQL</Button>
              </TabsContent>

              <TabsContent value="reset" className="space-y-4">
                <p className="text-xs text-destructive font-bold">
                  ⚠️ WARNING: This will delete ALL data in your Supabase cloud database.
                </p>
                <div className="bg-muted p-4 rounded-lg overflow-x-auto border border-destructive/20">
                  <pre className="text-[10px] text-foreground font-mono leading-relaxed">
{`DROP TABLE IF EXISTS bills;
CREATE TABLE bills (
  id TEXT PRIMARY KEY,
  customer_name TEXT NOT NULL,
  mobile TEXT NOT NULL,
  address TEXT,
  referral TEXT,
  advance NUMERIC DEFAULT 0,
  discount NUMERIC DEFAULT 0,
  status TEXT NOT NULL,
  total_cost NUMERIC DEFAULT 0,
  damage_charges NUMERIC DEFAULT 0,
  transportation_charges NUMERIC DEFAULT 0,
  event_date DATE,
  event_time TEXT,
  expected_return_date DATE,
  payment_promise_date DATE,
  items JSONB DEFAULT '[]'::jsonb,
  return_history JSONB DEFAULT '[]'::jsonb,
  payments JSONB DEFAULT '[]'::jsonb,
  created_by TEXT,
  notes TEXT,
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc'::text, now())
);
ALTER TABLE bills ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Enable all access for all users" ON bills FOR ALL USING (true) WITH CHECK (true);

DROP TABLE IF EXISTS employees;
CREATE TABLE employees (
  id TEXT PRIMARY KEY,
  name TEXT NOT NULL,
  mobile TEXT,
  role TEXT NOT NULL,
  pin TEXT NOT NULL
);
