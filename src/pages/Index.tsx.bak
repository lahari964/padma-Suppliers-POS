  price NUMERIC DEFAULT 0
);
ALTER TABLE inventory ENABLE ROW LEVEL SECURITY;
CREATE POLICY "Enable all access for inventory" ON inventory FOR ALL USING (true) WITH CHECK (true);`}
                  </pre>
                </div>
                <Button variant="destructive" className="w-full" onClick={() => {
                  navigator.clipboard.writeText(`DROP TABLE IF EXISTS bills;
CREATE TABLE bills (
  id TEXT PRIMARY KEY,
  customer_name TEXT NOT NULL,
  mobile TEXT NOT NULL,
  address TEXT,
  referral TEXT,
  advance NUMERIC DEFAULT 0,
  discount NUMERIC DEFAULT 0,
  status TEXT NOT NULL,
  total_cost NUMERIC DEFAULT 0,
  damage_charges NUMERIC DEFAULT 0,
  transportation_charges NUMERIC DEFAULT 0,
  event_date DATE,
  event_time TEXT,
  expected_return_date DATE,
  payment_promise_date DATE,
  items JSONB DEFAULT '[]'::jsonb,
  return_history JSONB DEFAULT '[]'::jsonb,
