  useEffect(() => {
    if (!currentUser) {
      navigate('/login');
    }
  }, [currentUser, navigate]);
  
  const [isChangePinOpen, setIsChangePinOpen] = useState(false);
  const [profileEditName, setProfileEditName] = useState('');
