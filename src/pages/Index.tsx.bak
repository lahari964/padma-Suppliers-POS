  useEffect(() => {
    localStorage.setItem('padma_sound', notificationSound);
  }, [notificationSound]);
  const supabaseUrl = 'https://mvywgorchatpwssinwxy.supabase.co';
  const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im12eXdnb3JjaGF0cHdzc2lud3h5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA1NzcyOTUsImV4cCI6MjA5NjE1MzI5NX0.yYr6NLeZ8_0xYp5damoMUnPFhvCws7ykCZlsoM26p68';
  const [isSyncing, setIsSyncing] = useState(false);
  const [lastSyncTime, setLastSyncTime] = useState<string | null>(localStorage.getItem('padma_last_sync'));
  const [lastSyncError, setLastSyncError] = useState<string | null>(null);
  const [showSqlDialog, setShowSqlDialog] = useState(false);

  const filteredBills = useMemo(() => {
    return [...bills].reverse().filter(b => {
      const matchesSearch = b.customerName.toLowerCase().includes(debouncedSearchTerm.toLowerCase()) || 
                            b.mobile.includes(debouncedSearchTerm);
      if (!matchesSearch) return false;
      if (handedByFilter === 'all') return true;
      
      const handledInItems = b.items.some(i => i.handledBy === handedByFilter);
      const handledInReturns = b.returnHistory.some(r => r.handledBy === handedByFilter);
      const handledInPayments = b.payments?.some(p => p.handledBy === handedByFilter);
      const createdByMatch = b.createdBy === handedByFilter;
      
      return handledInItems || handledInReturns || handledInPayments || createdByMatch;
    });
  }, [bills, debouncedSearchTerm, handedByFilter]);

  const getBillDisplayInfo = useCallback((bill: Bill): { status: Bill['status'], dispatchedCount: number, upcomingCount: number } => {
    if (bill.status === 'Paid' || bill.status === 'Pending') {
      return { status: bill.status, dispatchedCount: 0, upcomingCount: 0 };
    }
    
    const todayStr = format(new Date(), 'yyyy-MM-dd');
    let dispatchedCount = 0;
    let upcomingCount = 0;
    
    bill.items.forEach(i => {
      if (i.issueDate <= todayStr) dispatchedCount += i.qtyIssued;
      else upcomingCount += i.qtyIssued;
    });
    
    let status: Bill['status'] = bill.status;
    if (dispatchedCount > 0 && upcomingCount > 0) status = 'Partially Active';
    else if (dispatchedCount > 0) status = 'Active';
    else if (upcomingCount > 0) status = 'Upcoming';
    
    return { status, dispatchedCount, upcomingCount };
  }, []);

  const upcomingBills = useMemo(() => {
    return filteredBills.filter(t => {
      const info = getBillDisplayInfo(t);
      return info.status === 'Upcoming' || info.status === 'Partially Active';
    });
  }, [filteredBills, getBillDisplayInfo]);

  const activeBills = useMemo(() => {
    return filteredBills.filter(t => {
      const info = getBillDisplayInfo(t);
      return info.status === 'Active' || info.status === 'Partially Active';
    });
  }, [filteredBills, getBillDisplayInfo]);

  const pendingBills = useMemo(() => {
    return filteredBills.filter(t => t.status === 'Pending');
  }, [filteredBills]);

  const settledRecordsBills = useMemo(() => {
    return filteredBills.filter(t => {
      if (t.status !== 'Paid') return false;
      let settledDate = '';
      if (t.returnHistory && t.returnHistory.length > 0) {
        settledDate = t.returnHistory[t.returnHistory.length - 1].date;
      } else if (t.payments && t.payments.length > 0) {
        settledDate = t.payments[t.payments.length - 1].date;
      }
      if (settledDateFrom && settledDate && settledDate < settledDateFrom) return false;
      if (settledDateTo && settledDate && settledDate > settledDateTo) return false;
      return true;
    });
  }, [filteredBills, settledDateFrom, settledDateTo]);

