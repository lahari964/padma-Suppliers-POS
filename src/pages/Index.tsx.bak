            </Tabs>
          </div>
        </DialogContent>
      </Dialog>


      {/* Print Section (Hidden on screen, visible on print) */}
      {selectedBill && receiptTemplate === 'standard' && (
        <div id="print-section" className="hidden print:block bg-white text-black font-sans">
          <div className="flex justify-between items-start mb-6">
            <div className="flex items-center gap-4">
              <img src="https://assets.cdn.filesafe.space/9YKSM9vJJwAmtxbBkIyB/media/6a136179fe2210f89e688b6d.png" alt="Logo" className="h-16 object-contain" />
              <div>
                <h1 className="text-3xl font-bold uppercase tracking-wide text-left">Padma Suppliers</h1>
                <p className="text-sm mt-1 text-left">Ganugapalem, Ongole-523001</p>
                <p className="text-xs text-gray-600 text-left">Premium Tenthouse & Event Rentals</p>
              </div>
            </div>
            <div className="text-right">
              <p className="text-sm font-bold">Invoice #: {selectedBill.id}</p>
              <p className="text-xs text-gray-500 mt-1">Generated:<br/>{format(new Date(), 'dd MMM yyyy, hh:mm a')}</p>
            </div>
          </div>
          
          <div className="border-t-2 border-black pt-2 mb-2">
            <p className="text-sm"><strong>Customer Name:</strong> {selectedBill.customerName}</p>
            <p className="text-sm"><strong>Mobile:</strong> {selectedBill.mobile}</p>
            {selectedBill.address && <p className="text-sm"><strong>Address:</strong> {selectedBill.address}</p>}
          </div>
          
          <div className="border-t-2 border-black pt-2 mb-4">
            <table className="w-full text-sm">
              <thead>
                <tr className="border-b border-black">
                  <th className="text-left py-2 font-bold">Equipment Returned</th>
                  <th className="text-center py-2 font-bold">Qty</th>
                  <th className="text-center py-2 font-bold">Time</th>
                  <th className="text-center py-2 font-bold">Rate</th>
                  <th className="text-right py-2 font-bold">Amount</th>
                </tr>
              </thead>
              <tbody>
                {/* Active Items */}
                {['Active', 'Upcoming'].includes(selectedBill.status) && selectedBill.items.map((item, i) => {
                  const missing = item.qtyIssued - item.qtyReturned;
                  if (missing <= 0) return null;
                  
                  const now = new Date();
                  const iDate = new Date(selectedBill.eventDate || item.issueDate);
                  const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                  let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                  if (daysRented < 1) daysRented = 1;

                  return (
                  <tr key={`active-${item.id}`} className="border-b border-gray-200 last:border-0">
                    <td className="py-3">
                      <div className="font-medium text-black">{item.name}</div>
                      <div className="text-xs text-gray-600 mt-1">Issued: {formatToDDMMYYYY(item.issueDate)} | By: {item.handledBy || selectedBill.createdBy || 'Admin'}</div>
                    </td>
                    <td className="py-3 text-center align-top pt-3">{missing}</td>
                    <td className="py-3 text-center align-top pt-3">{daysRented} Days</td>
                    <td className="py-3 text-center align-top pt-3">₹{item.price}/day</td>
                    <td className="py-3 text-right align-top pt-3 text-gray-500 italic">₹{item.price * missing * daysRented} (Est.)</td>
                  </tr>
                  );
                })}
                
                {/* Returned Items */}
                {selectedBill.returnHistory.flatMap(log => 
                  log.items.map((item, i) => {
                    const matchedItem = selectedBill.items.find(bi => bi.name === item.name);
                    const issueDate = matchedItem ? formatToDDMMYYYY(matchedItem.issueDate) : 'N/A';
                    const retDate = formatToDDMMYYYY(log.date);
                    const rate = matchedItem ? matchedItem.price : Math.round(item.cost / item.qty / item.days);
                    
                    return (
                      <tr key={`returned-${log.date}-${i}`} className="border-b border-gray-200 last:border-0">
                        <td className="py-3">
                          <div className="font-medium text-black">{item.name} <span className="text-[10px] bg-gray-100 px-1 py-0.5 rounded text-gray-500 ml-1">Returned</span></div>
                          <div className="text-xs text-gray-600 mt-1">Issued: {issueDate} | Ret: {retDate} | By: {log.handledBy || 'Admin'}</div>
                        </td>
                        <td className="py-3 text-center align-top pt-3">{item.qty}</td>
                        <td className="py-3 text-center align-top pt-3">{item.days} Days</td>
                        <td className="py-3 text-center align-top pt-3">₹{rate}/day</td>
                        <td className="py-3 text-right align-top pt-3">₹{item.cost}</td>
                      </tr>
                    );
                  })
                )}



                {selectedBill.items.every(i => i.qtyIssued === 0) && selectedBill.returnHistory.length === 0 && (
                  <tr>
                    <td colSpan={5} className="py-4 text-center text-gray-500 italic">No items issued yet.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
          
          <div className="border-t-2 border-black pt-2 flex flex-col items-end text-sm space-y-1 mb-2">
            <div className="w-64 flex justify-between">
              <span className="font-bold">{['Active', 'Upcoming'].includes(selectedBill.status) ? 'Items Total (Est.):' : 'Items Total:'}</span>
              <span>₹{(() => {
                let cost = selectedBill.totalCost - (selectedBill.transportationCharges || 0) - (selectedBill.damageCharges || 0);
                if (['Active', 'Upcoming'].includes(selectedBill.status)) {
                  const now = new Date();
                  selectedBill.items.forEach(item => {
                    const missing = item.qtyIssued - item.qtyReturned;
                    if (missing > 0) {
                      const iDate = new Date(selectedBill.eventDate || item.issueDate);
                      const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                      let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                      if (daysRented < 1) daysRented = 1;
                      cost += missing * item.price * daysRented;
                    }
                  });
                }
                return cost;
              })()}</span>
            </div>
            {selectedBill.transportationCharges ? (
              <div className="w-64 flex justify-between text-foreground">
                <span className="font-bold">Transportation Cost:</span>
                <span>+ ₹{selectedBill.transportationCharges}</span>
              </div>
            ) : null}
            {selectedBill.damageCharges ? (
              <div className="w-64 flex justify-between text-destructive">
                <span className="font-bold">Damage Charges:</span>
                <span>+ ₹{selectedBill.damageCharges}</span>
              </div>
            ) : null}
            {selectedBill.discount > 0 && (
              <div className="w-64 flex justify-between text-emerald-600">
                <span className="font-bold">Discount:</span>
                <span>- ₹{selectedBill.discount}</span>
              </div>
            )}
            {selectedBill.payments && selectedBill.payments.length > 0 ? (
              <>
                <div className="w-64 flex justify-between font-bold mb-1">
                  <span>Payments Received:</span>
                </div>
                {selectedBill.payments.map((p, idx) => (
                  <div key={idx} className="w-64 flex justify-between text-gray-600 text-xs">
                    <span>{formatToDDMMYYYY(p.date)}:</span>
                    <span>- ₹{p.amount}</span>
                  </div>
                ))}
                <div className="w-64 flex justify-between mt-1 border-t border-gray-200 pt-1">
                  <span className="font-bold">Total Paid:</span>
                  <span>- ₹{selectedBill.advance}</span>
                </div>
              </>
            ) : (
              <div className="w-64 flex justify-between">
                <span className="font-bold">Advance Received:</span>
                <span>- ₹{selectedBill.advance}</span>
              </div>
            )}
          </div>
          
          <div className="border-t-2 border-black pt-2 flex flex-col items-end text-sm space-y-1 mb-2">
            <div className="w-64 flex justify-between font-bold text-lg border-b border-black pb-1 mb-2">
              <span>Grand Total:</span>
              <span>₹{(() => {
                let cost = selectedBill.totalCost;
                if (['Active', 'Upcoming'].includes(selectedBill.status)) {
                  const now = new Date();
                  selectedBill.items.forEach(item => {
                    const missing = item.qtyIssued - item.qtyReturned;
                    if (missing > 0) {
                      const iDate = new Date(selectedBill.eventDate || item.issueDate);
                      const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                      let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                      if (daysRented < 1) daysRented = 1;
                      cost += missing * item.price * daysRented;
                    }
                  });
                }
                return cost;
              })()}</span>
            </div>
            <div className="w-64 flex justify-between font-bold">
              {(() => {
                let cost = selectedBill.totalCost;
                if (['Active', 'Upcoming'].includes(selectedBill.status)) {
                  const now = new Date();
                  selectedBill.items.forEach(item => {
                    const missing = item.qtyIssued - item.qtyReturned;
                    if (missing > 0) {
                      const iDate = new Date(selectedBill.eventDate || item.issueDate);
                      const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                      let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                      if (daysRented < 1) daysRented = 1;
                      cost += missing * item.price * daysRented;
                    }
                  });
                }
                const bal = cost - selectedBill.advance - (selectedBill.discount || 0);
                if (bal < 0) {
                  return (
                    <>
                      <span>Refund Due:</span>
                      <span>₹{Math.abs(bal)}</span>
                    </>
                  );
                }
                return (
                  <>
                    <span>{['Active', 'Upcoming'].includes(selectedBill.status) ? 'Est. Balance Due:' : 'Final Balance:'}</span>
                    <span>₹{bal}</span>
                  </>
                );
              })()}
            </div>
          </div>
          
          <div className="text-center text-xs text-black">
            {['Paid', 'Pending'].includes(selectedBill.status) ? 'All items returned. ' : ''}Thank you for choosing Padma Suppliers!
          </div>
        </div>
      )}

      {selectedBill && receiptTemplate === 'dmart' && (
        <div id="print-section" className={`hidden print:block bg-white text-black font-mono mx-auto p-2 ${thermalSize === '112mm' ? 'max-w-[112mm] text-base' : thermalSize === '80mm' ? 'max-w-[80mm] text-sm' : 'max-w-[58mm] text-[11px]'}`}>
           <div className="text-center mb-3">
             <h1 className={`${thermalSize === '112mm' ? 'text-xl' : thermalSize === '80mm' ? 'text-lg' : 'text-base'} font-bold uppercase`}>Padma Suppliers</h1>
             <p className="text-xs">Premium Tenthouse & Event Rentals</p>
             <p className="text-[10px]">Ganugapalem, Ongole-523001</p>
             <p className="text-xs mt-1">--------------------------------</p>
             <p className="text-xs text-left">Bill No: {selectedBill.id}</p>
             <p className="text-xs text-left">Date: {format(new Date(), 'dd/MM/yyyy hh:mm a')}</p>
             <p className="text-xs text-left">Customer: {selectedBill.customerName}</p>
             <p className="text-xs text-left">Mob: {selectedBill.mobile}</p>
             {selectedBill.address && <p className="text-xs text-left">Addr: {selectedBill.address}</p>}
             <p className="text-xs">--------------------------------</p>
           </div>
           
           <table className="w-full text-xs mb-3">
             <thead>
               <tr className="border-b border-black border-dashed">
                 <th className="text-left py-1">Item</th>
                 <th className="text-right py-1">Qty</th>
                 <th className="text-right py-1">Amt</th>
               </tr>
             </thead>
             <tbody>
               {/* Active Items */}
               {['Active', 'Upcoming'].includes(selectedBill.status) && selectedBill.items.map((item, i) => {
                  const missing = item.qtyIssued - item.qtyReturned;
                  if (missing <= 0) return null;
                  
                  const issueDate = formatToDDMMYYYY(item.issueDate);
                  
                  const now = new Date();
                  const iDate = new Date(selectedBill.eventDate || item.issueDate);
                  const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                  let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                  if (daysRented < 1) daysRented = 1;

                  return (
                  <tr key={`active-${item.id}`}>
                    <td className="py-1">
                      <div className="truncate max-w-[120px]">{item.name}</div>
                      <div className="text-[10px] text-gray-500">{daysRented}d @ {item.price}/d</div>
                      <div className="text-[9px] text-gray-500">Out: {issueDate} | By: {item.handledBy || selectedBill.createdBy || 'Admin'}</div>
                    </td>
                    <td className="py-1 text-right align-top">{missing}</td>
                    <td className="py-1 text-right align-top text-[10px] italic">{item.price * missing * daysRented}*</td>
                  </tr>
                  );
                })}

                {/* Returned Items */}
                {selectedBill.returnHistory.flatMap(log => 
                  log.items.map((item, i) => {
                    const matchedItem = selectedBill.items.find(bi => bi.name === item.name);
                    const issueDate = matchedItem ? formatToDDMMYYYY(matchedItem.issueDate) : 'N/A';
                    const retDate = formatToDDMMYYYY(log.date);
                    const rate = item.qty > 0 && item.days > 0 ? Math.round(item.cost / item.qty / item.days) : 0;
                    return (
                      <tr key={`returned-${log.date}-${i}`}>
                        <td className="py-1">
                          <div className="truncate max-w-[120px]">{item.name} (Ret)</div>
                          <div className="text-[10px] text-gray-500">{item.days}d @ {rate}/d</div>
                          <div className="text-[9px] text-gray-500">Out: {issueDate} | In: {retDate} | By: {log.handledBy || 'Admin'}</div>
                        </td>
                        <td className="py-1 text-right align-top">{item.qty}</td>
                        <td className="py-1 text-right align-top">{item.cost}</td>
                       </tr>
                    );
                  })
                )}
             </tbody>
            </table>


           
            <div className="text-xs border-t border-black border-dashed pt-2 space-y-1">
              <div className="flex justify-between font-bold">
                <span>{['Active', 'Upcoming'].includes(selectedBill.status) ? 'ITEMS (EST)' : 'ITEMS TOTAL'}</span>
                <span>Rs {(() => {
                  let cost = selectedBill.totalCost - (selectedBill.transportationCharges || 0) - (selectedBill.damageCharges || 0);
                  if (['Active', 'Upcoming'].includes(selectedBill.status)) {
                    const now = new Date();
                    selectedBill.items.forEach(item => {
                      const missing = item.qtyIssued - item.qtyReturned;
                      if (missing > 0) {
                        const iDate = new Date(selectedBill.eventDate || item.issueDate);
                        const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                        let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                        if (daysRented < 1) daysRented = 1;
                        cost += missing * item.price * daysRented;
                      }
                    });
                  }
                  return cost;
                })()}</span>
              </div>
              {selectedBill.transportationCharges ? (
                <div className="flex justify-between text-foreground">
                  <span>TRANSPORT COST</span>
                  <span>+ Rs {selectedBill.transportationCharges}</span>
                </div>
              ) : null}
              {selectedBill.damageCharges ? (
                <div className="flex justify-between text-destructive">
                  <span>DAMAGE CHG</span>
                  <span>+ Rs {selectedBill.damageCharges}</span>
                </div>
              ) : null}
             {selectedBill.discount > 0 && (
               <div className="flex justify-between">
                 <span>DISCOUNT</span>
                 <span>- Rs {selectedBill.discount}</span>
               </div>
             )}
             {selectedBill.payments && selectedBill.payments.length > 0 ? (
               <>
                 <div className="font-bold mt-1">PAYMENTS:</div>
                 {selectedBill.payments.map((p, idx) => (
                   <div key={idx} className="flex justify-between text-[10px]">
                     <span>{formatToDDMMYYYY(p.date)}</span>
                     <span>- Rs {p.amount}</span>
                   </div>
                 ))}
                 <div className="flex justify-between border-t border-black border-dashed pt-1 mt-1">
                   <span>TOTAL PAID</span>
                   <span>- Rs {selectedBill.advance}</span>
                 </div>
               </>
             ) : (
               <div className="flex justify-between">
                 <span>ADVANCE</span>
                 <span>- Rs {selectedBill.advance}</span>
               </div>
             )}
              <div className="flex justify-between border-t border-black border-dashed pt-1 mt-1 font-bold">
                <span>GRAND TOTAL</span>
                <span>Rs {(() => {
                  let cost = selectedBill.totalCost;
                  if (['Active', 'Upcoming'].includes(selectedBill.status)) {
                    const now = new Date();
                    selectedBill.items.forEach(item => {
                      const missing = item.qtyIssued - item.qtyReturned;
                      if (missing > 0) {
                        const iDate = new Date(selectedBill.eventDate || item.issueDate);
                        const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                        let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                        if (daysRented < 1) daysRented = 1;
                        cost += missing * item.price * daysRented;
                      }
                    });
                  }
                  return cost;
                })()}</span>
              </div>
              <div className="flex justify-between border-t border-black border-dashed pt-1 font-bold text-sm mt-1">
                {(() => {
                 let cost = selectedBill.totalCost;
                 if (['Active', 'Upcoming'].includes(selectedBill.status)) {
                   const now = new Date();
                   selectedBill.items.forEach(item => {
                     const missing = item.qtyIssued - item.qtyReturned;
                     if (missing > 0) {
                       const iDate = new Date(selectedBill.eventDate || item.issueDate);
                       const diffTime = Math.max(0, now.getTime() - iDate.getTime());
                       let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                       if (daysRented < 1) daysRented = 1;
                       cost += missing * item.price * daysRented;
                     }
                   });
                 }
                 const bal = cost - selectedBill.advance - (selectedBill.discount || 0);
                 if (bal < 0) {
                   return (
                     <>
                       <span>REFUND DUE</span>
                       <span>Rs {Math.abs(bal)}</span>
                     </>
                   );
                 }
                 return (
                   <>
                     <span>{['Active', 'Upcoming'].includes(selectedBill.status) ? 'EST. BALANCE' : 'BALANCE'}</span>
                     <span>Rs {bal}</span>
                   </>
                 );
               })()}
              </div>
           </div>
           
           <div className="text-center text-xs mt-4">
             <p>--------------------------------</p>
             <p>Thank You! Visit Again.</p>
             <p>--------------------------------</p>
           </div>
      </div>
      )}
    </SidebarProvider>
  );
}

const getCategoryIcon = (category: string) => {
  switch(category) {
    case 'Tents & Canopies': return <Tent className="w-5 h-5" />;
    case 'Furniture': return <Armchair className="w-5 h-5" />;
    case 'Lighting & Electrical': return <Lightbulb className="w-5 h-5" />;
    case 'Decor & Linens': return <Sparkles className="w-5 h-5" />;
    case 'Structures': return <Box className="w-5 h-5" />;
    case 'Cooling & Heating': return <Fan className="w-5 h-5" />;
    case 'Audio/Visual': return <Speaker className="w-5 h-5" />;
    default: return <Box className="w-5 h-5" />;
  }
};

const InventoryModernListRow = memo(function InventoryModernListRow({ item, onAdd }: { item: InventoryItem, onAdd: (item: InventoryItem, qty: string, price: number) => void }) {
  const [qty, setQty] = useState('1');
  const [customPrice, setCustomPrice] = useState(item.price.toString());
  const [showSuccess, setShowSuccess] = useState(false);

  return (
    <div className="flex items-center justify-between p-3 border-b border-border/50 last:border-0 hover:bg-muted/30 transition-colors gap-4 group">
      <div className="flex items-center gap-3 flex-1 min-w-0">
        <div className="p-2 bg-secondary/10 text-secondary rounded-lg shrink-0">
          {getCategoryIcon(item.category)}
        </div>
        <div className="min-w-0">
          <h3 className="font-semibold text-sm text-foreground truncate">{item.name}</h3>
          <div className="flex items-center gap-2 mt-0.5">
            <div className="flex items-center text-xs text-muted-foreground bg-muted/30 px-2 py-0.5 rounded-md border border-border/20">
              <span className="mr-1">₹</span>
              <Input 
                type="number" 
                value={customPrice} 
                onChange={e => setCustomPrice(e.target.value)} 
                className="h-5 w-20 px-1 py-0 text-xs bg-transparent border-none shadow-none focus-visible:ring-0 font-bold text-foreground" 
              />
              <span className="ml-1">/day</span>
            </div>
          </div>
        </div>
      </div>
      <div className="flex items-center gap-2 shrink-0">
        <Input type="number" min="1" value={qty} onChange={e => setQty(e.target.value)} className="h-8 w-12 px-1 text-sm text-center rounded-lg" />
        <Button 
          size="sm" 
          className={cn(
            "h-8 w-8 p-0 rounded-lg transition-all duration-300",
            showSuccess ? "bg-emerald-500 hover:bg-emerald-600 text-white scale-110" : "bg-primary hover:bg-primary/90 text-primary-foreground"
          )}
          onClick={() => { 
            onAdd(item, qty, Number(customPrice) || item.price); 
            setQty('1'); 
            setCustomPrice(item.price.toString()); 
            setShowSuccess(true);
            setTimeout(() => setShowSuccess(false), 1000);
          }}
        >
          {showSuccess ? <Check className="w-4 h-4" /> : <Plus className="w-4 h-4" />}
        </Button>
      </div>
    </div>
  );
});

function AddNewItemForm({ inventory, onAdd }: { inventory: InventoryItem[], onAdd: (invId: string, qty: number, date: string, price: number) => void }) {
  const [selectedInv, setSelectedInv] = useState(inventory[0]?.id || '');
  const [qty, setQty] = useState('1');
  const [issueDate, setIssueDate] = useState(format(new Date(), 'yyyy-MM-dd'));
  const [customPrice, setCustomPrice] = useState(inventory[0]?.price?.toString() || '0');

  useEffect(() => {
    const item = inventory.find(i => i.id === selectedInv);
    if (item) setCustomPrice(item.price.toString());
  }, [selectedInv, inventory]);

  return (
    <div className="grid grid-cols-1 sm:grid-cols-6 gap-4 items-end">
      <div className="space-y-2 sm:col-span-2">
        <Label>Item</Label>
        <select 
          className="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
          value={selectedInv} 
          onChange={e => setSelectedInv(e.target.value)}
        >
          {inventory.map(i => <option key={i.id} value={i.id}>{i.name} (₹{i.price})</option>)}
        </select>
      </div>
      <div className="space-y-2">
        <Label>Rate (₹)</Label>
        <Input type="number" min="0" value={customPrice} onChange={e => setCustomPrice(e.target.value)} />
      </div>
      <div className="space-y-2">
        <Label>Qty</Label>
        <Input type="number" min="1" value={qty} onChange={e => setQty(e.target.value)} />
      </div>
      <div className="sm:col-span-2">
        <DatePicker 
          label="Issue Date" 
          date={issueDate} 
          setDate={setIssueDate} 
        />
      </div>
      <div className="sm:col-span-6 flex justify-end mt-2">
        <Button onClick={() => onAdd(selectedInv, parseInt(qty) || 1, issueDate, Number(customPrice) || 0)}>Add to Bill</Button>
      </div>
    </div>
  );
}

function LogReturnForm({ bill, userRole, onLog }: { bill: Bill, userRole: string, onLog: (date: string, qtys: Record<string, number>, discount: number, damage: number, transport: number) => void }) {
  const [returnDate, setReturnDate] = useState(format(new Date(), 'yyyy-MM-dd'));
  const [returnQtys, setReturnQtys] = useState<Record<string, number>>({});
  const [damagedQtys, setDamagedQtys] = useState<Record<string, number>>({});
  const [discount, setDiscount] = useState<number | string>(bill.discount ?? '');
  const [damageCharges, setDamageCharges] = useState<number | string>('');
  const [transportCharges, setTransportCharges] = useState<number | string>('');

  const unreturned = bill.items.filter(i => i.qtyIssued > i.qtyReturned);
  const hasDamages = Object.values(damagedQtys).some(q => q > 0);

  if (unreturned.length === 0) {
    return <div className="py-6 text-center text-muted-foreground">All items have been returned.</div>;
  }

  return (
    <div className="space-y-6">
      <DatePicker 
        label="Date of Return" 
        date={returnDate} 
        setDate={setReturnDate} 
        maxDate={format(new Date(), 'yyyy-MM-dd')}
      />
      
      <div>
        <div className="flex justify-between items-end mb-2">
          <Label className="block">Items to Return</Label>
          <Button size="sm" variant="outline" className="h-7 text-[10px]" onClick={() => {
            const allQtys: Record<string, number> = {};
            unreturned.forEach(item => {
              allQtys[item.id] = item.qtyIssued - item.qtyReturned;
            });
            setReturnQtys(allQtys);
          }}>All Returned</Button>
        </div>
        <Table>
          <TableHeader className="bg-muted/50">
            <TableRow className="border-border">
              <TableHead>Item</TableHead>
              <TableHead>Missing</TableHead>
              <TableHead className="w-[120px]">Returning</TableHead>
              <TableHead className="w-[120px]">Damaged</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {unreturned.map(item => {
              const missing = item.qtyIssued - item.qtyReturned;
              const currentReturn = returnQtys[item.id] || 0;
              return (
                <TableRow key={item.id} className="border-border">
                  <TableCell className="text-foreground">{item.name}</TableCell>
                  <TableCell className="text-destructive font-medium">{missing}</TableCell>
                  <TableCell>
                    <Input 
                      type="number" 
                      min="0" 
                      max={missing} 
                      value={returnQtys[item.id] || ''} 
                      onChange={e => {
                        let val = parseInt(e.target.value);
                        if (isNaN(val) || val < 0) val = 0;
                        if (val > missing) val = missing;
                        setReturnQtys(prev => ({ ...prev, [item.id]: val }));
                        if ((damagedQtys[item.id] || 0) > val) {
                          setDamagedQtys(prev => ({ ...prev, [item.id]: val }));
                        }
                      }}
                    />
                  </TableCell>
                  <TableCell>
                    <Input 
                      type="number" 
                      min="0" 
                      max={currentReturn || missing} 
                      value={damagedQtys[item.id] || ''} 
                      onChange={e => {
                        let val = parseInt(e.target.value);
                        if (isNaN(val) || val < 0) val = 0;
                        const maxDamaged = currentReturn || missing;
                        if (val > maxDamaged) val = maxDamaged;
                        setDamagedQtys(prev => ({ ...prev, [item.id]: val }));
                      }}
                      placeholder="0"
                    />
                  </TableCell>
                </TableRow>
              );
            })}
          </TableBody>
        </Table>
      </div>

      <div className="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4 border-t border-border">
        {hasDamages ? (
          <div className="space-y-2 animate-in fade-in zoom-in duration-300">
            <Label className="text-destructive">Damage Charges (₹)</Label>
            <Input type="number" value={damageCharges} onChange={e => setDamageCharges(e.target.value)} placeholder="0" className="border-destructive/50 focus-visible:ring-destructive" />
          </div>
        ) : <div />}
        <div className="space-y-2">
          <Label>Add Transport (₹)</Label>
          <Input type="number" value={transportCharges} onChange={e => setTransportCharges(e.target.value)} placeholder="0" />
        </div>
        <div className="space-y-2">
          <Label>Add Discount (₹)</Label>
          <Input type="number" value={discount} disabled={!['Admin', 'Manager'].includes(userRole)} onChange={e => setDiscount(e.target.value)} placeholder="0" />
        </div>
      </div>
      <p className="text-[10px] text-muted-foreground">Global discount is updated.{hasDamages ? ' Damage charges are added to total.' : ''}</p>

      <DialogFooter>
        <Button onClick={() => onLog(returnDate, returnQtys, Number(discount) || 0, hasDamages ? (Number(damageCharges) || 0) : 0, Number(transportCharges) || 0)} className="bg-emerald-600 hover:bg-emerald-700 text-white w-full">
          Confirm Return & Calculate
        </Button>
      </DialogFooter>
    </div>
  );
}

