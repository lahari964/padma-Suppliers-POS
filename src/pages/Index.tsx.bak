const formatToDDMMYYYY = (dateStr: string) => {
  if (!dateStr) return '';
  try {
    return format(new Date(dateStr), 'dd-MM-yyyy');
  } catch(e) {
    return dateStr;
  }
};

const parseDateLocal = (dateStr: string) => {
  if (!dateStr) return new Date();
  const [y, m, d] = dateStr.split('-').map(Number);
  return new Date(y, m - 1, d);
};

function DatePicker({ 
  date, 
  setDate, 
  label, 
  minDate, 
  maxDate 
}: { 
  date: string; 
  setDate: (date: string) => void; 
  label?: string;
  minDate?: string;
  maxDate?: string;
}) {
  const selectedDate = date ? parseDateLocal(date) : undefined;
  
  return (
    <div className="space-y-2 flex flex-col">
      {label && <Label>{label}</Label>}
      <Popover>
        <PopoverTrigger asChild>
          <Button
            variant={"outline"}
            className={cn(
              "w-full justify-start text-left font-normal border-border bg-background h-10",
              !date && "text-muted-foreground"
            )}
          >
            <CalendarIcon className="mr-2 h-4 w-4" />
            {date ? format(selectedDate!, "PPP") : <span>Pick a date</span>}
          </Button>
        </PopoverTrigger>
        <PopoverContent className="w-auto p-0 bg-card border-border" align="start">
          <Calendar
            mode="single"
            selected={selectedDate}
            onSelect={(d) => d && setDate(format(d, 'yyyy-MM-dd'))}
            disabled={(d) => {
              if (minDate) {
                const min = parseDateLocal(minDate);
                min.setHours(0, 0, 0, 0);
                const current = new Date(d);
                current.setHours(0, 0, 0, 0);
                if (current < min) return true;
              }
              if (maxDate) {
                const max = parseDateLocal(maxDate);
                max.setHours(23, 59, 59, 999);
                if (d > max) return true;
              }
              return false;
            }}
            initialFocus
          />
        </PopoverContent>
      </Popover>
    </div>
  );
}

function CustomPagination({ 
  currentPage, 
  totalItems, 
  itemsPerPage, 
  onPageChange,
  onItemsPerPageChange
}: { 
  currentPage: number, 
  totalItems: number, 
  itemsPerPage: number, 
  onPageChange: (page: number) => void,
  onItemsPerPageChange: (items: number) => void
}) {
  const totalPages = Math.ceil(totalItems / itemsPerPage);
  const startItem = (currentPage - 1) * itemsPerPage + 1;
  const endItem = Math.min(currentPage * itemsPerPage, totalItems);

  if (totalItems <= 10) return null;

  return (
    <div className="py-4 px-4 border-t border-border bg-card/50 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div className="flex items-center gap-4">
        <div className="flex items-center gap-2">
          <span className="text-sm text-muted-foreground whitespace-nowrap">Show</span>
          <Select
            value={itemsPerPage.toString()}
            onValueChange={(val) => {
              onItemsPerPageChange(Number(val));
              onPageChange(1); // Reset to first page when changing page size
            }}
          >
            <SelectTrigger className="h-8 w-[70px]">
              <SelectValue />
            </SelectTrigger>
            <SelectContent>
              {[5, 10, 20, 50, 100].map(size => (
                <SelectItem key={size} value={size.toString()}>{size}</SelectItem>
              ))}
            </SelectContent>
          </Select>
          <span className="text-sm text-muted-foreground whitespace-nowrap">entries</span>
        </div>
        <span className="text-sm text-muted-foreground hidden sm:inline-block">
          Showing {startItem} to {endItem} of {totalItems} entries
        </span>
      </div>

      <Pagination className="justify-end w-auto mx-0">
        <PaginationContent>
          <PaginationItem>
            <PaginationPrevious 
              onClick={() => onPageChange(Math.max(1, currentPage - 1))}
              className={currentPage === 1 ? "pointer-events-none opacity-50" : "cursor-pointer"}
            />
          </PaginationItem>
          
          <PaginationItem>
            <span className="text-sm text-muted-foreground px-4">
              Page {currentPage} of {Math.max(1, totalPages)}
            </span>
          </PaginationItem>

          <PaginationItem>
            <PaginationNext 
              onClick={() => onPageChange(Math.min(totalPages, currentPage + 1))}
              className={currentPage >= totalPages ? "pointer-events-none opacity-50" : "cursor-pointer"}
            />
          </PaginationItem>
        </PaginationContent>
      </Pagination>
    </div>
  );
}

function TimePicker({ time, setTime }: { time: string, setTime: (time: string) => void }) {
  const [isOpen, setIsOpen] = useState(false);
  
  const hours = Array.from({ length: 12 }, (_, i) => i === 0 ? 12 : i);
  const minutes = Array.from({ length: 60 }, (_, i) => i.toString().padStart(2, '0'));
  
  const [selectedHour, setSelectedHour] = useState(time ? (parseInt(time.split(':')[0]) % 12 || 12).toString() : '12');
  const [selectedMinute, setSelectedMinute] = useState(time ? time.split(':')[1] : '00');
  const [selectedPeriod, setSelectedPeriod] = useState(time ? (parseInt(time.split(':')[0]) >= 12 ? 'PM' : 'AM') : 'AM');

  useEffect(() => {
    if (time) {
      const h = parseInt(time.split(':')[0]);
      setSelectedHour((h % 12 || 12).toString());
      setSelectedMinute(time.split(':')[1]);
      setSelectedPeriod(h >= 12 ? 'PM' : 'AM');
    }
  }, [time]);

  const handleTimeChange = (h: string, m: string, p: string) => {
    let hour24 = parseInt(h);
    if (p === 'PM' && hour24 !== 12) hour24 += 12;
    if (p === 'AM' && hour24 === 12) hour24 = 0;
    
    const formattedHour = hour24.toString().padStart(2, '0');
    setTime(`${formattedHour}:${m}`);
  };

  return (
    <Popover open={isOpen} onOpenChange={setIsOpen}>
      <PopoverTrigger asChild>
        <Button variant="outline" className={cn("w-32 justify-start text-left font-normal border-border bg-background h-10", !time && "text-muted-foreground")}>
          <Clock className="mr-2 h-4 w-4" />
          {time ? (
            (() => {
              const h = parseInt(time.split(':')[0]);
              const m = time.split(':')[1];
              const p = h >= 12 ? 'PM' : 'AM';
              const h12 = h % 12 || 12;
              return `${h12.toString().padStart(2, '0')}:${m} ${p}`;
            })()
          ) : <span>Time</span>}
        </Button>
      </PopoverTrigger>
      <PopoverContent className="w-auto p-3 bg-card border-border shadow-md rounded-xl" align="start">
        <div className="flex gap-2 h-48">
          <div className="w-16 overflow-y-auto rounded-md border border-border flex flex-col p-1 gap-1 custom-scrollbar">
            {hours.map(h => (
              <Button 
                key={h} 
                variant={selectedHour === h.toString() ? "default" : "ghost"} 
                size="sm" 
                className="w-full text-center h-8 shrink-0"
                onClick={() => {
                  setSelectedHour(h.toString());
                  handleTimeChange(h.toString(), selectedMinute, selectedPeriod);
                }}
              >
                {h.toString().padStart(2, '0')}
              </Button>
            ))}
          </div>
          <div className="w-16 overflow-y-auto rounded-md border border-border flex flex-col p-1 gap-1 custom-scrollbar">
            {minutes.map(m => (
              <Button 
                key={m} 
                variant={selectedMinute === m ? "default" : "ghost"} 
                size="sm" 
                className="w-full text-center h-8 shrink-0"
                onClick={() => {
                  setSelectedMinute(m);
                  handleTimeChange(selectedHour, m, selectedPeriod);
                }}
              >
                {m}
              </Button>
            ))}
          </div>
          <div className="flex flex-col gap-1 w-16">
            <Button 
              variant={selectedPeriod === 'AM' ? "default" : "outline"} 
              className="flex-1 rounded-md border-border shrink-0"
              onClick={() => {
                setSelectedPeriod('AM');
                handleTimeChange(selectedHour, selectedMinute, 'AM');
              }}
            >
              AM
            </Button>
            <Button 
              variant={selectedPeriod === 'PM' ? "default" : "outline"} 
              className="flex-1 rounded-md border-border shrink-0"
              onClick={() => {
                setSelectedPeriod('PM');
                handleTimeChange(selectedHour, selectedMinute, 'PM');
              }}
            >
              PM
            </Button>
          </div>
        </div>
      </PopoverContent>
    </Popover>
  );
}

export function useDebounce<T>(value: T, delay: number): T {
  const [debouncedValue, setDebouncedValue] = useState<T>(value);
  useEffect(() => {
    const handler = setTimeout(() => {
      setDebouncedValue(value);
    }, delay);
    return () => clearTimeout(handler);
  }, [value, delay]);
  return debouncedValue;
}

