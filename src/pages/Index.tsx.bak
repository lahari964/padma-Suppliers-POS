  }, [activeBills, activePage, itemsPerPage]);

  const paginatedPendingBills = useMemo(() => {
    const start = (pendingPage - 1) * itemsPerPage;
    return pendingBills.slice(start, start + itemsPerPage);
  }, [pendingBills, pendingPage, itemsPerPage]);

  const paginatedSettledBills = useMemo(() => {
    const start = (settledPage - 1) * itemsPerPage;
    return settledRecordsBills.slice(start, start + itemsPerPage);
  }, [settledRecordsBills, settledPage, itemsPerPage]);

  const filteredInventory = useMemo(() => {
    return inventory.filter(item => 
      item.name.toLowerCase().includes(debouncedInventorySearchTerm.toLowerCase())
    );
  }, [inventory, debouncedInventorySearchTerm]);



  const getTimelineEvents = useCallback((bill: Bill) => {
    const events: any[] = [];
    let createdTimestamp = Date.now();
    if (bill.id.startsWith('BLL-')) {
      createdTimestamp = parseInt(bill.id.replace('BLL-', ''));
    } else {
      createdTimestamp = parseInt(bill.id);
    }
    
    // Validate if it's a realistic timestamp (between 2020 and 2035)
    if (isNaN(createdTimestamp) || createdTimestamp < 1577836800000 || createdTimestamp > 2051222400000) {
      if (bill.items && bill.items.length > 0 && bill.items[0].issueDate) {
        createdTimestamp = bill.items[0].issueTimestamp || parseDateLocal(bill.items[0].issueDate).getTime();
      } else {
        createdTimestamp = Date.now();
      }
    }

    const itemsCost = bill.items.reduce((sum, item) => sum + (item.price * item.qtyIssued * item.days), 0);

    events.push({
      date: format(new Date(createdTimestamp), 'yyyy-MM-dd'),
      timestamp: createdTimestamp,
      type: 'created',
      description: `Order created by ${bill.createdBy || 'Admin'}`,
      details: `Initial Bill Amount: ₹${itemsCost}`
    });

    if (bill.advance > 0) {
      events.push({
        date: format(new Date(createdTimestamp), 'yyyy-MM-dd'),
        timestamp: createdTimestamp + 1000,
        type: 'payment',
        description: `Advance Payment Received`,
        details: `Amount: ₹${bill.advance}`,
        handledBy: bill.createdBy || 'Admin'
      });
    }

    if (bill.discount && bill.discount > 0) {
      events.push({
        date: format(new Date(createdTimestamp), 'yyyy-MM-dd'),
        timestamp: createdTimestamp + 2000,
        type: 'discount',
        description: `Discount Applied`,
        details: `Amount: ₹${bill.discount}`,
        handledBy: bill.createdBy || 'Admin'
      });
    }

    if (bill.transportationCharges && bill.transportationCharges > 0) {
      events.push({
        date: format(new Date(createdTimestamp), 'yyyy-MM-dd'),
        timestamp: createdTimestamp + 3000,
        type: 'charge',
        description: `Transportation Charges Added`,
        details: `Amount: ₹${bill.transportationCharges}`,
        handledBy: bill.createdBy || 'Admin'
      });
    }

    const sentGroups: Record<string, BillItem[]> = {};
    bill.items.forEach(item => {
      if (!sentGroups[item.issueDate]) sentGroups[item.issueDate] = [];
      sentGroups[item.issueDate].push(item);
    });
    
    Object.keys(sentGroups).forEach(date => {
      const items = sentGroups[date];
      const totalQty = items.reduce((sum, i) => sum + i.qtyIssued, 0);
      const ts = items[0].issueTimestamp || parseDateLocal(date).getTime();
      events.push({
        date,
        timestamp: ts,
        type: 'sent',
        description: `Dispatched ${totalQty} items`,
        details: items.map(i => `${i.qtyIssued}x ${i.name}`).join(', '),
        handledBy: items[0].handledBy || bill.createdBy || 'Admin'
      });
    });

    bill.returnHistory.forEach((log, idx) => {
      const totalQty = log.items.reduce((sum, i) => sum + i.qty, 0);
      events.push({
        date: log.date,
        timestamp: parseDateLocal(log.date).getTime() + 86400000 + idx, 
        type: 'returned',
        description: `Returned ${totalQty} items`,
        details: log.items.map(i => `${i.qty}x ${i.name}`).join(', '),
        handledBy: log.handledBy || 'Admin'
      });
    });

    if (bill.damageCharges && bill.damageCharges > 0) {
      // Assume damage charges are added during the last return or at the end
      const lastReturnTs = bill.returnHistory.length > 0 
        ? parseDateLocal(bill.returnHistory[bill.returnHistory.length - 1].date).getTime() + 86400000 * 1.5
        : Date.now();
      
      events.push({
        date: format(new Date(lastReturnTs), 'yyyy-MM-dd'),
        timestamp: lastReturnTs,
        type: 'charge',
        description: `Damage Charges Added`,
        details: `Amount: ₹${bill.damageCharges}`,
        handledBy: 'Admin'
      });
    }

    if (bill.payments) {
      bill.payments.forEach((p, idx) => {
        events.push({
          date: p.date,
          timestamp: parseDateLocal(p.date).getTime() + 86400000 * 2 + idx, 
          type: 'payment',
          description: `Payment Received`,
          details: `Amount: ₹${p.amount}`,
          handledBy: p.handledBy || 'Admin'
        });
      });
    }

    const sortedEvents = events.sort((a, b) => a.timestamp - b.timestamp);
    
    // Calculate running balance for display
    let currentBal = itemsCost + (bill.transportationCharges || 0) - (bill.discount || 0);
    
    return sortedEvents.map(ev => {
      let balanceStr = '';
      if (ev.type === 'payment') {
        const amt = parseFloat(ev.details.replace('Amount: ₹', ''));
        currentBal -= amt;
        balanceStr = ` | Balance: ₹${currentBal}`;
      } else if (ev.type === 'charge' && ev.description.includes('Damage')) {
        const amt = parseFloat(ev.details.replace('Amount: ₹', ''));
        currentBal += amt;
        balanceStr = ` | Balance: ₹${currentBal}`;
      }
      
      return {
        ...ev,
        balanceUpdate: balanceStr
      };
    });
  }, []);

  // --- SUPABASE CLIENT ---
  const cleanSupabaseUrl = supabaseUrl.replace(/\/rest\/v1\/?$/, '').replace(/\/$/, '');
  const supabase = React.useMemo(() => 
    cleanSupabaseUrl && supabaseKey ? createClient(cleanSupabaseUrl, supabaseKey) : null
  , [cleanSupabaseUrl, supabaseKey]);

  const syncToSupabase = async (billsToSync: Bill[], isManual = false): Promise<{success: boolean, error?: string}> => {
    if (!supabase) return { success: false, error: "Supabase not configured" };
    setIsSyncing(true);
    const toastId = isManual ? toast.loading("Syncing with cloud...") : null;
    
    try {
      const { error } = await supabase
        .from('bills')
        .upsert(
          billsToSync.map(b => ({
            id: b.id,
            customer_name: b.customerName,
            mobile: b.mobile,
            address: b.address || '',
            referral: b.referral || '',
            advance: b.advance || 0,
            discount: b.discount || 0,
            status: b.status,
            total_cost: b.totalCost || 0,
            damage_charges: b.damageCharges || 0,
            transportation_charges: b.transportationCharges || 0,
            event_date: b.eventDate || null,
            event_time: b.eventTime || null,
            expected_return_date: b.expectedReturnDate || null,
            payment_promise_date: b.paymentPromiseDate || null,
            items: b.items || [],
            return_history: b.returnHistory || [],
            payments: b.payments || [],
            created_by: b.createdBy || null,
            notes: b.notes || null,
            updated_at: new Date().toISOString()
          })),
          { onConflict: 'id' }
        );
      
      if (error) {
        console.error('Supabase Error:', error);
        throw new Error(error.message || "Database connection error");
      }
      
      const nowTime = format(new Date(), 'HH:mm:ss');
      setLastSyncTime(nowTime);
      setLastSyncError(null);
      localStorage.setItem('padma_last_sync', nowTime);
      if (isManual) {
        toast.success("Sync Completed: Data is now safe in the cloud!", { id: toastId });
      }
      return { success: true };
    } catch (err: any) {
      console.error('Supabase Sync Error:', err);
      const errorMsg = err.message || "Check your internet connection.";
      setLastSyncError(errorMsg);
      
      toast.error(`Sync Failed: ${errorMsg}`, { 
        id: toastId,
        description: "Check your internet or database settings. Local data is still safe."
      });
      
      return { success: false, error: errorMsg };
    } finally {
      setIsSyncing(false);
    }
  };

  const fetchFromSupabase = async () => {
    if (!supabase) return false;
    setIsSyncing(true);
    try {
      const { data, error } = await supabase
        .from('bills')
        .select('*')
        .order('updated_at', { ascending: false });
      
      if (error) throw error;
      if (data) {
        const nowTime = format(new Date(), 'HH:mm:ss');
        setLastSyncTime(nowTime);
        localStorage.setItem('padma_last_sync', nowTime);
        const remoteBills = data.map(row => ({
          id: row.id,
          customerName: row.customer_name,
          mobile: row.mobile,
          address: row.address || '',
          referral: row.referral,
          advance: row.advance,
          discount: row.discount,
          status: row.status,
          totalCost: row.total_cost,
          damageCharges: row.damage_charges,
          transportationCharges: row.transportation_charges,
          eventDate: row.event_date,
          eventTime: row.event_time,
          expectedReturnDate: row.expected_return_date,
          paymentPromiseDate: row.payment_promise_date,
          items: row.items,
          returnHistory: row.return_history,
          payments: row.payments,
          createdBy: row.created_by,
          notes: row.notes
        } as Bill));
        setBills(remoteBills);
        setLastSyncError(null);
        return true;
      }
      return false;
    } catch (err: any) {
      console.error('Supabase Fetch Error:', err);
      setLastSyncError(err.message || "Connection failed during health check.");
      return false;
    } finally {
      setIsSyncing(false);
    }
  };

  const syncInventoryToSupabase = async (invToSync: InventoryItem[]) => {
    if (!supabase) return;
    try {
      const { error: upsertError } = await supabase.from('inventory').upsert(
        invToSync.map(i => ({ id: i.id, name: i.name, price: i.price, category: i.category })),
        { onConflict: 'id' }
      );
      if (upsertError) throw upsertError;

      const currentIds = invToSync.map(i => i.id);
      const { data: existing } = await supabase.from('inventory').select('id');
      if (existing) {
        const toDelete = existing.filter(e => !currentIds.includes(e.id)).map(e => e.id);
        if (toDelete.length > 0) {
          await supabase.from('inventory').delete().in('id', toDelete);
        }
      }
    } catch (err) {
      console.error('Inventory sync error:', err);
    }
  };

  const fetchInventoryFromSupabase = async () => {
    if (!supabase) return false;
    try {
      const { data, error } = await supabase.from('inventory').select('*');
      if (error) throw error;
      if (data && data.length > 0) {
        setInventory(data.map(row => ({
          id: row.id,
          name: row.name,
          price: row.price,
          category: row.category
        })));
        return true;
      }
      return false;
    } catch (err) {
      console.error('Inventory fetch error:', err);
      return false;
    }
  };

  const testSupabaseConnection = async () => {
    if (!supabase) {
      alert("Please enter both Supabase URL and Anon Key first.");
      return;
    }
    setIsSyncing(true);
    try {
      const { data, error } = await supabase.from('bills').select('id').limit(1);
      if (error) throw error;
      alert("Connection Successful! Your database is ready.");
    } catch (err: any) {
      console.error('Connection Test Failed:', err);
      alert(`Connection Failed: ${err.message || "Make sure you have run the SQL query in Supabase Editor."}`);
    } finally {
      setIsSyncing(false);
    }
  };

  // --- LIFECYCLE ---
  useEffect(() => {
    // 1. Load from local storage first for instant loading
    const saved = localStorage.getItem('padma_bills');
    if (saved) {
      try {
        setBills(JSON.parse(saved));
      } catch (e) {
        console.error("Failed to parse bills", e);
      }
    }

    // 2. Automatically fetch from Supabase to restore/sync data from cloud (Health Check)
    const initFetch = async () => {
      if (supabase) {
        // Fetch Employees
        try {
          const { data: empData, error: empError } = await supabase.from('employees').select('*');
          if (!empError && empData) {
            if (empData.length > 0) {
              setEmployees(empData);
            } else {
              await supabase.from('employees').insert(defaultEmployees);
            }
          }
        } catch (e) {
          console.error("Employee fetch error", e);
        }

        // Fetch Inventory
        try {
          const invSuccess = await fetchInventoryFromSupabase();
          if (!invSuccess && inventory.length > 0) {
            await syncInventoryToSupabase(inventory);
          }
        } catch (e) {
          console.error("Inventory init fetch error", e);
        }

        const success = await fetchFromSupabase();
        if (!success) {
          toast.error("Database Health Check Failed", {
            description: "Could not connect to cloud. Please check settings or repair database."
          });
        } else {
          toast.success("Database Health Check Passed", {
            description: "Connected to cloud successfully."
          });
        }
      }
    };
    initFetch();

    const savedPrefs = localStorage.getItem('padma_prefs');
    if (savedPrefs) {
      try {
        const prefs = JSON.parse(savedPrefs);
        if (prefs.receiptTemplate) setReceiptTemplate(prefs.receiptTemplate);
        if (prefs.thermalSize) setThermalSize(prefs.thermalSize);
        if (prefs.isCompactView !== undefined) setIsCompactView(prefs.isCompactView);
        if (prefs.colorTheme) setColorTheme(prefs.colorTheme);
      } catch (e) {
        console.error("Failed to parse prefs", e);
      }
    }
  }, []);

  useEffect(() => {
    localStorage.setItem('padma_bills', JSON.stringify(bills));
  }, [bills]);

  useEffect(() => {
    localStorage.setItem('padma_employees', JSON.stringify(employees));
  }, [employees]);

  useEffect(() => {
    localStorage.setItem('padma_inventory', JSON.stringify(inventory));
  }, [inventory]);

  useEffect(() => {
    if (isInventoryManageOpen) setEditingInventory([...inventory]);
  }, [isInventoryManageOpen, inventory]);

  useEffect(() => {
    if (currentUser) {
      sessionStorage.setItem('padma_current_user', JSON.stringify(currentUser));
    } else {
      sessionStorage.removeItem('padma_current_user');
    }
  }, [currentUser]);

  useEffect(() => {
    localStorage.setItem('padma_prefs', JSON.stringify({ receiptTemplate, thermalSize, isCompactView, colorTheme }));
  }, [receiptTemplate, thermalSize, isCompactView, colorTheme]);

  useEffect(() => {
    const root = document.documentElement;
    root.classList.remove('theme-purple', 'theme-blue', 'theme-green', 'theme-orange', 'theme-rose');
    root.classList.add(colorTheme);
  }, [colorTheme]);

  useEffect(() => {
    if (activeTab === 'settings' && currentUser) {
      setProfileEditName(currentUser.name);
      setProfileEditMobile(employees.find((e: any) => e.id === currentUser.id)?.mobile || '');
    }
  }, [activeTab, currentUser, employees]);

  useEffect(() => {
    if (activeTab === 'settings' && searchTerm && currentUser) {
      const q = searchTerm.toLowerCase();
      const tabs = [
        { id: 'profile', match: 'profile'.includes(q) },
        { id: 'general', match: 'general'.includes(q) || 'theme'.includes(q) || 'receipt'.includes(q) || 'dark'.includes(q) || 'mode'.includes(q) },
        { id: 'staff', match: 'staff'.includes(q) && currentUser.role === 'Admin' },
        { id: 'inventory', match: 'inventory'.includes(q) && ['Admin', 'Manager'].includes(currentUser.role) },
        { id: 'export', match: ('export'.includes(q) || 'download'.includes(q)) && ['Admin', 'Manager'].includes(currentUser.role) },
        { id: 'database', match: 'database'.includes(q) && currentUser.role === 'Admin' }
      ];
      const currentTabObj = tabs.find(t => t.id === activeSettingsTab);
      if (currentTabObj && !currentTabObj.match) {
        const firstVisible = tabs.find(t => t.match);
        if (firstVisible) {
          setActiveSettingsTab(firstVisible.id);
        }
      }
    }
  }, [searchTerm, activeTab, activeSettingsTab, currentUser]);

  // --- GOOGLE SHEETS SYNC ---
  const syncToCloud = async (action: string, payload: any, currentBills: Bill[] = bills, showFeedback = false): Promise<{success: boolean, error?: string}> => {
    // Supabase Cloud Sync (Two-way Persistence)
    if (supabase) {
      return await syncToSupabase(currentBills, showFeedback);
    } else if (showFeedback) {
      toast.info("Saved locally (Cloud sync not configured)");
      return { success: true };
    }
    return { success: true };
  };

  // --- ACTIONS ---
  const handleStageItem = useCallback((item: InventoryItem, qtyStr: string, customPrice: number) => {
    const qty = parseInt(qtyStr);
    if (isNaN(qty) || qty <= 0) return;
    
    setStagedItems(prev => {
      const existing = prev.find(i => i.inventoryId === item.id && i.price === customPrice);
      if (existing) {
        return prev.map(i => (i.inventoryId === item.id && i.price === customPrice) ? { ...i, qty: i.qty + qty } : i);
      }
      return [...prev, { inventoryId: item.id, name: item.name, price: customPrice, qty }];
    });
  }, []);

  const handleRemoveStaged = (inventoryId: string) => {
    setStagedItems(prev => prev.filter(i => i.inventoryId !== inventoryId));
  };

  const handleCreateBill = async () => {
    if (!customerName || !mobile || stagedItems.length === 0) {
      alert('Please fill required fields (Name, Mobile) and add items.');
      return;
    }
    if (mobile.length !== 10) {
      alert('Mobile number must be exactly 10 digits.');
      return;
    }

    const now = new Date();
    const todayStr = format(now, 'yyyy-MM-dd');
    const isFutureOrder = eventDate > todayStr;

    if (!isFutureOrder) {
      const emptyFields = [];
      if (!address) emptyFields.push('Customer Address');
      if (advance === '') emptyFields.push('Advance Paid');
      if (!expectedReturnDate) emptyFields.push('Expected Return Date');
      
      if (emptyFields.length > 0) {
        setWarningMessage(emptyFields);
        setIsWarningOpen(true);
        return;
      }
    }

    await proceedCreateBill();
  };

  const proceedCreateBill = async () => {
    const now = new Date();
    const todayStr = format(now, 'yyyy-MM-dd');
    const isFutureOrder = eventDate > todayStr;
    const status = isFutureOrder ? 'Upcoming' : 'Active';

    const newBill: Bill = {
      id: `BLL-${Date.now()}`,
      customerName,
      mobile,
      address,
      referral,
      advance: Number(advance) || 0,
      discount: 0,
      status,
      totalCost: Number(transportationCharges) || 0,
      transportationCharges: Number(transportationCharges) || 0,
      eventDate,
      eventTime,
      expectedReturnDate,
      items: stagedItems.map(staged => ({
        id: `ITI-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`,
        inventoryId: staged.inventoryId,
        name: staged.name,
        price: staged.price,
        issueDate: eventDate || todayStr,
        issueTimestamp: new Date(eventDate || now).getTime(),
        qtyIssued: staged.qty,
        qtyReturned: 0,
        days: 1,
        handledBy: currentUser?.name || 'Admin'
      })),
      returnHistory: [],
      payments: advance ? [{ date: todayStr, amount: Number(advance), handledBy: currentUser?.name }] : [],
      createdBy: currentUser?.name,
      notes
    };

    const updatedBills = [...bills, newBill];
    const syncResult = await syncToCloud('CREATE_BILL', newBill, updatedBills, true);
    if (!syncResult.success) {
      alert(`Cannot create bill: Database sync failed.\n\nError: ${syncResult.error || 'Check your database connection or columns.'}\n\nPlease run the Database Repair SQL in Settings -> Database.`);
      return;
    }
    setBills(updatedBills);
    sendPushNotification("New Bill Created", `Bill ${newBill.id} created for ${customerName}`);
    
    if (isFutureOrder) {
      const itemsList = stagedItems.map(i => `${i.qty}x ${i.name}`).join(', ');
      const message = `Hello ${customerName},\n\nYour advance booking with Padma Suppliers is confirmed!\n\nEvent Date: ${formatToDDMMYYYY(eventDate)}\nAdvance Paid: ₹${Number(advance) || 0}\nItems Booked:\n${itemsList}\n\nThank you for choosing us!`;
      const waNumber = mobile.length === 10 ? `91${mobile}` : mobile;
      window.open(`https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`, '_blank');
    }

    setStagedItems([]);
    setCustomerName('');
    setMobile('');
    setAddress('');
    setReferral('');
    setAdvance('');
    setTransportationCharges('');
    setEventDate(format(new Date(), 'yyyy-MM-dd'));
    setEventTime('');
    setExpectedReturnDate('');
    setNotes('');
  };

  const handleCancelOrder = (billId: string) => {
    if (confirm('Are you sure you want to cancel and delete this upcoming order?')) {
      const updatedBills = bills.filter(b => b.id !== billId);
      setBills(updatedBills);
      syncToCloud('CANCEL_ORDER', { id: billId }, updatedBills);
    }
  };



  // --- MATH ENGINE & MODALS ---
const handleLogReturn = (returnDate: string, returnQtys: Record<string, number>, newDiscount: number, damageCharges: number = 0, additionalTransport: number = 0) => {
    if (!selectedBill) return;
    const rDate = new Date(returnDate);
    
    let batchCost = 0;
    const returnedItemsLog: ReturnLogItem[] = [];
    
    const updatedItems = selectedBill.items.map(item => {
      const qtyToReturn = returnQtys[item.id] || 0;
      if (qtyToReturn <= 0) return item;
      
      const iDate = new Date(selectedBill.eventDate || item.issueDate);
      const diffTime = Math.max(0, rDate.getTime() - iDate.getTime());
      let daysRented = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
      if (daysRented < 1) daysRented = 1;
      
      const cost = qtyToReturn * item.price * daysRented;
      batchCost += cost;
      
      returnedItemsLog.push({ name: item.name, qty: qtyToReturn, days: daysRented, cost });
      
      return { ...item, qtyReturned: item.qtyReturned + qtyToReturn };
    });
    
    const allReturned = updatedItems.every(i => i.qtyReturned >= i.qtyIssued);

    const newTotalCost = selectedBill.totalCost + batchCost + damageCharges + additionalTransport;
    const balance = newTotalCost - selectedBill.advance - newDiscount;
    
    const updatedBill: Bill = {
      ...selectedBill,
      items: updatedItems,
      discount: newDiscount,
      damageCharges: (selectedBill.damageCharges || 0) + damageCharges,
      transportationCharges: (selectedBill.transportationCharges || 0) + additionalTransport,
      totalCost: newTotalCost,
      status: allReturned ? (balance === 0 ? 'Paid' : 'Pending') : 'Active',
      returnHistory: returnedItemsLog.length > 0 
        ? [...selectedBill.returnHistory, { date: returnDate, items: returnedItemsLog, handledBy: currentUser?.name }]
        : selectedBill.returnHistory
    };
    
    const updatedBills = bills.map(t => t.id === updatedBill.id ? updatedBill : t);
    setBills(updatedBills);
    sendPushNotification("Return Logged", `Items returned for Bill ${updatedBill.id}`);
    syncToCloud('LOG_RETURN', updatedBill, updatedBills);
    setIsReturnOpen(false);
  };

  const handleMarkAsPaid = (billId: string) => {
    const bill = bills.find(b => b.id === billId);
    if (!bill) return;

    const balance = bill.totalCost - bill.advance - (bill.discount || 0);
    const updatedBill: Bill = {
      ...bill,
      status: 'Paid' as const,
      advance: bill.advance + balance,
      payments: balance !== 0 ? [...(bill.payments || []), { date: format(new Date(), 'yyyy-MM-dd'), amount: balance, handledBy: currentUser?.name }] : bill.payments
    };

    const updatedBills = bills.map(b => b.id === billId ? updatedBill : b);
    setBills(updatedBills);
    sendPushNotification("Payment Recorded", `Bill ${updatedBill.id} marked as Paid`);
    syncToCloud('MARK_PAID', updatedBill, updatedBills);
  };

  const handleAddPayment = () => {
    if (!selectedBill) return;
    const amount = Number(paymentAmount) || 0;
    const discountVal = Number(paymentDiscount) || 0;
    
    if (amount <= 0 && discountVal <= 0) return;

    const newAdvance = selectedBill.advance + amount;
    const newDiscount = (selectedBill.discount || 0) + discountVal;
    const newPayments = amount > 0 
      ? [...(selectedBill.payments || []), { date: paymentDate, amount, handledBy: currentUser?.name }]
      : (selectedBill.payments || []);
    
    const balance = selectedBill.totalCost - newAdvance - newDiscount;
    const newStatus = balance === 0 && selectedBill.status === 'Pending' ? 'Paid' : selectedBill.status;

    const updatedBill: Bill = {
      ...selectedBill,
      advance: newAdvance,
      discount: newDiscount,
      payments: newPayments,
      status: newStatus
    };

    const updatedBills = bills.map(b => b.id === updatedBill.id ? updatedBill : b);
    setBills(updatedBills);
    syncToCloud('ADD_PAYMENT', updatedBill, updatedBills);
    setIsPaymentOpen(false);
    setPaymentAmount('');
    setPaymentDiscount('');
    setPaymentDate(format(new Date(), 'yyyy-MM-dd'));
  };

  const handleDeleteItem = (billId: string, itemId: string) => {
    const bill = bills.find(b => b.id === billId);
    if (!bill) return;

    const updatedBill = { ...bill, items: bill.items.filter(i => i.id !== itemId) };
    const updatedBills = bills.map(b => b.id === billId ? updatedBill : b);
    
    setBills(updatedBills);
    syncToCloud('DELETE_ITEM', { billId, itemId }, updatedBills);

    if (selectedBill && selectedBill.id === billId) {
      setSelectedBill(updatedBill);
    }
  };

  const handleSendItem = (billId: string, itemId: string) => {
    const bill = bills.find(b => b.id === billId);
    if (!bill) return;

    const todayStr = format(new Date(), 'yyyy-MM-dd');
    
    const updatedItems = bill.items.map(i => 
      i.id === itemId 
        ? { ...i, issueDate: todayStr, issueTimestamp: new Date(todayStr).getTime(), handledBy: currentUser?.name } 
        : i
    );

    const hasDispatched = updatedItems.some(i => i.issueDate <= todayStr);
    const newStatus = (bill.status === 'Pending' || bill.status === 'Paid') 
      ? bill.status 
      : (hasDispatched ? 'Active' : 'Upcoming');

    const updatedBill = { ...bill, items: updatedItems, status: newStatus as any };
    const updatedBills = bills.map(b => b.id === billId ? updatedBill : b);
    
    setBills(updatedBills);
    if (selectedBill && selectedBill.id === billId) {
      setSelectedBill(updatedBill);
    }
    syncToCloud('SEND_ITEM', updatedBill, updatedBills);
    sendPushNotification("Item Dispatched", `Item sent for Bill ${updatedBill.id}`);
    toast.success("Item marked as sent!");
  };

const handleAddNewItemToBill = (inventoryId: string, qty: number, customIssueDate: string, customPrice: number) => {
    if (!selectedBill) return;
    const invItem = inventory.find(i => i.id === inventoryId);
    if (!invItem) return;
    
    const newItem: BillItem = {
      id: `ITI-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`,
      inventoryId: invItem.id,
      name: invItem.name,
      price: customPrice,
      issueDate: customIssueDate,
      issueTimestamp: new Date(customIssueDate).getTime(),
      qtyIssued: qty,
      qtyReturned: 0,
      days: 1,
      handledBy: currentUser?.name || 'Admin'
    };
    
    const updatedItems = [...selectedBill.items, newItem];
    const todayStr = format(new Date(), 'yyyy-MM-dd');
    const hasDispatched = updatedItems.some(i => i.issueDate <= todayStr);
    const newStatus = (selectedBill.status === 'Pending' || selectedBill.status === 'Paid') 
      ? selectedBill.status 
      : (hasDispatched ? 'Active' : 'Upcoming');

    const updatedBill = { ...selectedBill, items: updatedItems, status: newStatus as any };
    const updatedBills = bills.map(t => t.id === updatedBill.id ? updatedBill : t);
    setBills(updatedBills);
    setSelectedBill(updatedBill);
    syncToCloud('ADD_ITEM', updatedBill, updatedBills);
  };

  const handleSplitItem = () => {
    if (!selectedBill || !splitItemId || !splitQty || splitQty <= 0) return;
    const itemToSplit = selectedBill.items.find(i => i.id === splitItemId);
    if (!itemToSplit || itemToSplit.qtyIssued <= splitQty) {
      toast.error("Invalid split quantity.");
      return;
    }

    const updatedOriginalItem = { ...itemToSplit, qtyIssued: itemToSplit.qtyIssued - splitQty };
    const newItem: BillItem = {
      ...itemToSplit,
      id: `ITI-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`,
      qtyIssued: splitQty,
      issueDate: splitDate,
      issueTimestamp: new Date(splitDate).getTime(),
      days: itemToSplit.days || 1,
      handledBy: currentUser?.name || 'Admin'
    };

    const updatedItems = selectedBill.items.map(i => i.id === splitItemId ? updatedOriginalItem : i);
    updatedItems.push(newItem);

    const todayStr = format(new Date(), 'yyyy-MM-dd');
    const hasDispatched = updatedItems.some(i => i.issueDate <= todayStr);
    const newStatus = (selectedBill.status === 'Pending' || selectedBill.status === 'Paid') 
      ? selectedBill.status 
      : (hasDispatched ? 'Active' : 'Upcoming');

    const updatedBill = { ...selectedBill, items: updatedItems, status: newStatus as any };
    const updatedBills = bills.map(b => b.id === updatedBill.id ? updatedBill : b);
    
    setBills(updatedBills);
    setSelectedBill(updatedBill);
    syncToCloud('SPLIT_ITEM', updatedBill, updatedBills);
    
    setSplitItemId(null);
    setSplitQty('');
  };

  const handleExportCSV = () => {
    const paidBills = bills.filter(t => {
      if (t.status !== 'Paid') return false;
      if (t.returnHistory.length === 0) return false;
      return t.returnHistory[t.returnHistory.length - 1].date.startsWith(exportMonth);
    });
    
    if (paidBills.length === 0) {
      alert('No settled bills found for the selected month.');
      return;
    }
    
    // Generate CSV
const headers = ['Bill ID', 'Customer', 'Mobile', 'Issue Date', 'Return Date', 'Advance', 'Discount', 'Total Cost', 'Status'];
    const rows = paidBills.map(t => {
      const issueDate = t.items.length > 0 ? formatToDDMMYYYY(t.items[0].issueDate) : 'N/A';
      const returnDate = t.returnHistory.length > 0 ? formatToDDMMYYYY(t.returnHistory[t.returnHistory.length - 1].date) : 'N/A';
      return [t.id, t.customerName, t.mobile, issueDate, returnDate, t.advance, t.discount || 0, t.totalCost - (t.discount || 0), t.status];
    });
    const csvContent = [headers.join(','), ...rows.map(e => e.join(','))].join('\n');
    
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', `Padma_Suppliers_Settled_${exportMonth}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  const handleExportAllCSV = () => {
    if (bills.length === 0) {
      alert('No data found to export.');
      return;
    }
    
    const headers = ['Bill ID', 'Customer', 'Mobile', 'Status', 'Event Date', 'Expected Return', 'Advance', 'Discount', 'Total Cost', 'Balance Due', 'Items'];
    const rows = bills.map(t => {
      const balance = t.totalCost - t.advance - (t.discount || 0);
      const itemsSummary = t.items.map(i => `${i.qtyIssued}x ${i.name}`).join('; ');
      return [
        t.id, 
        t.customerName, 
        t.mobile, 
        t.status, 
        t.eventDate || 'N/A', 
        t.expectedReturnDate || 'N/A', 
        t.advance, 
        t.discount || 0, 
        t.totalCost, 
        balance,
        `"${itemsSummary}"`
      ];
    });
    
    const csvContent = [headers.join(','), ...rows.map(e => e.join(','))].join('\n');
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', `Padma_Full_Backup_${format(new Date(), 'dd_MM_yyyy')}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  const handlePrintReceipt = (bill: Bill) => {
    setSelectedBill(bill);
    setTimeout(() => {
      window.print();
    }, 100);
  };



  const handleDownloadBackup = () => {
    const data = JSON.stringify(bills);
    const blob = new Blob([data], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `Padma_${format(new Date(), 'dd_MMMM_yyyy')}.json`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  const handleRestoreBackup = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const parsed = JSON.parse(event.target?.result as string);
        if (Array.isArray(parsed)) {
          setBills(parsed);
          if (supabase) {
            syncToSupabase(parsed);
          }
          alert('Data restored successfully and pushed to cloud!');
        } else {
          alert('Invalid backup file format.');
        }
      } catch (err) {
        alert('Failed to read backup file.');
      }
    };
    reader.readAsText(file);
    e.target.value = ''; // Reset input
  };







  const [selectedDate, setSelectedDate] = useState<Date | undefined>(new Date());

  const parseDateLocal = (dateStr: string) => {
    if (!dateStr) return new Date();
    const [y, m, d] = dateStr.split('-').map(Number);
    return new Date(y, m - 1, d);
  };

  const displayBills = useMemo(() => {
    const dateStr = selectedDate ? format(selectedDate, 'yyyy-MM-dd') : '';
    return bills.filter(b => {
      const matchesSearch = b.customerName.toLowerCase().includes(debouncedSearchTerm.toLowerCase()) || b.mobile.includes(debouncedSearchTerm);
      if (!matchesSearch) return false;

      if (calendarFilter === 'all') {
        return b.eventDate === dateStr || (b.expectedReturnDate === dateStr && (getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active')) || (b.paymentPromiseDate === dateStr && b.status === 'Pending');
      }
      if (calendarFilter === 'Upcoming') return b.eventDate === dateStr && (getBillDisplayInfo(b).status === 'Upcoming' || getBillDisplayInfo(b).status === 'Partially Active');
      if (calendarFilter === 'Active') return b.expectedReturnDate === dateStr && (getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active');
      if (calendarFilter === 'Pending') return b.paymentPromiseDate === dateStr && b.status === 'Pending';
      if (calendarFilter === 'Paid') return b.status === 'Paid' && (b.returnHistory.some(log => log.date === dateStr) || b.payments?.some(p => p.date === dateStr));
      return false;
    });
  }, [bills, selectedDate, debouncedSearchTerm, calendarFilter]);

  const calendarDateStr = selectedDate ? format(selectedDate, 'yyyy-MM-dd') : '';

  const { dailyTotal, monthlyTotal, totalPending } = useMemo(() => {
    const today = format(new Date(), 'yyyy-MM-dd');
    const thisMonth = format(new Date(), 'yyyy-MM');
    let daily = 0, monthly = 0, pending = 0;
    bills.forEach(bill => {
      if (bill.status !== 'Paid') {
        pending += bill.totalCost - bill.advance - (bill.discount || 0);
      }
      if (bill.payments) {
        bill.payments.forEach(p => {
          if (p.date === today) daily += p.amount;
          if (p.date.startsWith(thisMonth)) monthly += p.amount;
        });
      }
    });
    return { dailyTotal: daily, monthlyTotal: monthly, totalPending: pending };
  }, [bills]);
  
  const monthlyRevenueData = useMemo(() => {
    const dataMap: Record<string, number> = {};
    const today = new Date();
    for (let i = 5; i >= 0; i--) {
      const d = new Date(today.getFullYear(), today.getMonth() - i, 1);
      const monthStr = format(d, 'MMM');
      dataMap[monthStr] = 0;
    }
    
    bills.forEach(bill => {
      if (bill.payments) {
        bill.payments.forEach(p => {
          const pDate = new Date(p.date);
          const monthStr = format(pDate, 'MMM');
          if (dataMap[monthStr] !== undefined) {
            dataMap[monthStr] += p.amount;
          }
        });
      }
    });
    
    return Object.entries(dataMap).map(([month, revenue]) => ({ month, revenue }));
  }, [bills]);

  const handleUpdateProfile = async () => {
    if (!profileEditName.trim()) {
      toast.error('Name cannot be empty');
      return;
    }
    if (!profileEditMobile.trim()) {
      toast.error('Mobile cannot be empty');
      return;
    }
    
    try {
      if (supabase) {
        const { error } = await supabase
          .from('employees')
          .update({ name: profileEditName, mobile: profileEditMobile })
          .eq('id', currentUser?.id);
          
        if (error) throw error;
      }
      
      const updatedEmployees = employees.map((e: any) => 
        e.id === currentUser?.id 
          ? { ...e, name: profileEditName, mobile: profileEditMobile } 
          : e
      );
      setEmployees(updatedEmployees);
      if (currentUser) {
        setCurrentUser({ ...currentUser, name: profileEditName });
      }
      toast.success('Profile updated successfully');
    } catch (e: any) {
      toast.error('Failed to update profile: ' + e.message);
    }
  };

  if (!currentUser) {
    return null;
  }

  return (
    <SidebarProvider>
      <div className={cn("flex min-h-screen w-full bg-background text-foreground print:bg-white print:min-h-0", isCompactView && "compact-tables")}>
        <Sidebar className="print:hidden border-r border-border bg-card">
          <SidebarHeader className="p-4 border-b border-border">
            <div className="flex items-center gap-3">
              <img src="https://assets.cdn.filesafe.space/9YKSM9vJJwAmtxbBkIyB/media/6a136179fe2210f89e688b6d.png" alt="Padma Suppliers" className="h-[30px] object-contain" />
              <h1 className="text-lg font-bold text-foreground">Padma Suppliers</h1>
            </div>
          </SidebarHeader>
          <SidebarContent className="p-2">
            <SidebarMenu>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'dashboard'} onClick={() => setActiveTab('dashboard')} className="h-10">
                  <LayoutDashboard className="w-5 h-5 mr-2" />
                  <span className="font-medium">Dashboard</span>
                </SidebarMenuButton>
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'home'} onClick={() => setActiveTab('home')} className="h-10">
                  <Home className="w-5 h-5 mr-2" />
                  <span className="font-medium">Home</span>
                </SidebarMenuButton>
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'upcoming'} onClick={() => setActiveTab('upcoming')} className="h-10">
                  <ListTodo className="w-5 h-5 mr-2" />
                  <span className="font-medium">Upcoming Orders</span>
                </SidebarMenuButton>
                {upcomingBills.length > 0 && <SidebarMenuBadge className="bg-primary text-primary-foreground">{upcomingBills.length}</SidebarMenuBadge>}
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'active'} onClick={() => setActiveTab('active')} className="h-10">
                  <Package className="w-5 h-5 mr-2" />
                  <span className="font-medium">Active Rentals</span>
                </SidebarMenuButton>
                {activeBills.length > 0 && <SidebarMenuBadge className="bg-primary text-primary-foreground">{activeBills.length}</SidebarMenuBadge>}
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'pending'} onClick={() => setActiveTab('pending')} className="h-10">
                  <IndianRupee className="w-5 h-5 mr-2" />
                  <span className="font-medium">Pending Bills</span>
                </SidebarMenuButton>
                {pendingBills.length > 0 && <SidebarMenuBadge className="bg-primary text-primary-foreground">{pendingBills.length}</SidebarMenuBadge>}
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'settled'} onClick={() => setActiveTab('settled')} className="h-10">
                  <History className="w-5 h-5 mr-2" />
                  <span className="font-medium">Settled Records</span>
                </SidebarMenuButton>
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'calendar'} onClick={() => setActiveTab('calendar')} className="h-10">
                  <CalendarDays className="w-5 h-5 mr-2" />
                  <span className="font-medium">Calendar View</span>
                </SidebarMenuButton>
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'settings' && activeSettingsTab === 'profile'} onClick={() => { setActiveTab('settings'); setActiveSettingsTab('profile'); }} className="h-10">
                  <UserCircle className="w-5 h-5 mr-2" />
                  <span className="font-medium">Edit Profile</span>
                </SidebarMenuButton>
              </SidebarMenuItem>
              <SidebarMenuItem>
                <SidebarMenuButton isActive={activeTab === 'settings' && activeSettingsTab !== 'profile'} onClick={() => { setActiveTab('settings'); if (activeSettingsTab === 'profile') setActiveSettingsTab('general'); }} className="h-10">
                  <Settings className="w-5 h-5 mr-2" />
                  <span className="font-medium">Settings</span>
                </SidebarMenuButton>
              </SidebarMenuItem>
            </SidebarMenu>
          </SidebarContent>
            <SidebarFooter className="p-4 border-t bg-muted/10">
            </SidebarFooter>
        </Sidebar>

        <div className="flex-1 flex flex-col min-w-0">
          <header className="bg-card shadow-sm border-b border-border px-4 sm:px-6 py-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 print:hidden">
            <div className="flex items-center gap-3 w-full md:w-auto justify-between md:justify-start">
              <div className="flex items-center gap-3">
                <SidebarTrigger className="-ml-2 mr-2" />
                <img src="https://assets.cdn.filesafe.space/9YKSM9vJJwAmtxbBkIyB/media/6a136179fe2210f89e688b6d.png" alt="Padma Suppliers" className="h-[30px] object-contain" />
                <h2 className="text-xl sm:text-2xl font-bold text-foreground">
                  Padma Suppliers
                </h2>
              </div>
            </div>
          <div className="flex flex-wrap items-center gap-2 sm:gap-4 w-full md:w-auto">
          {bills.filter(b => b.status === 'Pending' && b.paymentPromiseDate && b.paymentPromiseDate <= format(new Date(), 'yyyy-MM-dd')).length > 0 && (
            <Button variant="destructive" size="sm" className="animate-pulse bg-destructive text-destructive-foreground font-semibold text-xs sm:text-sm h-8 sm:h-10" onClick={() => setActiveTab('pending')}>
              ⚠️ {bills.filter(b => b.status === 'Pending' && b.paymentPromiseDate && b.paymentPromiseDate <= format(new Date(), 'yyyy-MM-dd')).length} Payment(s) Due
            </Button>
          )}
          {bills.filter(b => (getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active') && b.expectedReturnDate === format(new Date(), 'yyyy-MM-dd')).length > 0 && (
            <Button variant="outline" size="sm" className="animate-bounce border-amber-500 text-amber-600 font-semibold text-xs sm:text-sm h-8 sm:h-10" onClick={() => setActiveTab('active')}>
              📅 {bills.filter(b => (getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active') && b.expectedReturnDate === format(new Date(), 'yyyy-MM-dd')).length} Return(s) Today
            </Button>
          )}
          <div className="flex flex-wrap gap-2 w-full sm:w-auto mt-2 sm:mt-0">
            {supabase && ['Admin', 'Manager'].includes(currentUser.role) && (
              <div className="flex items-center gap-2 px-2 sm:px-3 py-1 bg-primary/5 rounded-full border border-primary/10">
                <div className={`w-2 h-2 rounded-full ${isSyncing ? 'bg-amber-500 animate-pulse' : 'bg-emerald-500'}`} />
                <span className="text-[10px] font-bold uppercase tracking-wider text-primary hidden sm:inline">
                  {lastSyncTime ? `Last Sync: ${lastSyncTime}` : "Cloud Sync Active"}
                </span>
                <Button variant="ghost" size="icon" className={`h-6 w-6 ml-1 ${isSyncing ? "animate-spin text-primary" : "text-muted-foreground"}`} onClick={() => syncToSupabase(bills, true)}>
                  <Upload className="w-3 h-3" />
                </Button>
                <Button variant="ghost" size="icon" className={`h-6 w-6 ml-1 ${isSyncing ? "animate-spin text-primary" : "text-muted-foreground"}`} onClick={fetchFromSupabase}>
                  <RefreshCw className="w-3 h-3" />
                </Button>
              </div>
            )}
            {/* Export button moved to settings */}
            <DropdownMenu>
              <DropdownMenuTrigger asChild>
                <Button variant="ghost" size="sm" className="text-muted-foreground hover:text-foreground h-8 sm:h-10 ml-2">
                  <UserCircle className="w-5 h-5 sm:mr-2" />
                  <span className="hidden sm:inline">{currentUser.name}</span>
                </Button>
              </DropdownMenuTrigger>
              <DropdownMenuContent align="end" className="w-48 bg-card border-border">
                <DropdownMenuLabel className="flex flex-col space-y-1 pb-2">
                  <span className="text-base font-bold">{currentUser.name}</span>
                  <span className="text-xs text-muted-foreground font-medium">Role: {currentUser.role}</span>
                  <span className="text-xs text-muted-foreground font-medium">Mobile: {employees.find(e => e.id === currentUser.id)?.mobile || 'N/A'}</span>
                </DropdownMenuLabel>
                <DropdownMenuSeparator />
                <DropdownMenuItem onClick={() => { setActiveTab('settings'); setActiveSettingsTab('profile'); }}>
                  <UserCircle className="w-4 h-4 mr-2" />
                  Edit Profile
                </DropdownMenuItem>
                <DropdownMenuItem onClick={() => { setActiveTab('settings'); if (activeSettingsTab === 'profile') setActiveSettingsTab('general'); }}>
                  <Settings className="w-4 h-4 mr-2" />
                  App Settings
                </DropdownMenuItem>
                <DropdownMenuSeparator />
                <DropdownMenuItem asChild>
                  <Link 
                    to="/login" 
                    onClick={() => {
                      sessionStorage.removeItem('padma_current_user');
                      setCurrentUser(null);
                    }} 
                    className="text-destructive focus:text-destructive w-full cursor-pointer flex items-center"
                  >
                    <CornerDownLeft className="w-4 h-4 mr-2" />
                    Logout
                  </Link>
                </DropdownMenuItem>
              </DropdownMenuContent>
            </DropdownMenu>
          </div>
        </div>
      </header>
      <main className="flex-1 overflow-y-auto p-4 sm:p-6 print:p-0">
        <div className="mb-4 print:hidden flex items-center justify-between">
          <h2 className="text-xl font-bold text-foreground flex items-center gap-2">
            {activeTab === 'dashboard' && <><LayoutDashboard className="w-5 h-5" /> Dashboard</>}
            {activeTab === 'home' && <><Home className="w-5 h-5" /> Home</>}
            {activeTab === 'upcoming' && <><ListTodo className="w-5 h-5" /> Upcoming Orders</>}
            {activeTab === 'active' && <><Package className="w-5 h-5" /> Active Rentals</>}
            {activeTab === 'pending' && <><IndianRupee className="w-5 h-5" /> Pending Bills</>}
            {activeTab === 'settled' && <><History className="w-5 h-5" /> Settled Records</>}
            {activeTab === 'calendar' && <><CalendarDays className="w-5 h-5" /> Calendar View</>}

            {activeTab === 'settings' && activeSettingsTab === 'profile' && <><UserCircle className="w-5 h-5" /> Edit Profile</>}
            {activeTab === 'settings' && activeSettingsTab !== 'profile' && <><Settings className="w-5 h-5" /> App Settings</>}
          </h2>
          {activeTab === 'settled' && (
            <div className="flex items-center gap-2">
              <Popover>
                <PopoverTrigger asChild>
                  <Button variant="outline" className="h-9 relative bg-background">
                    <Filter className="w-4 h-4 mr-2" />
                    Filter Dates
                    {(settledDateFrom || settledDateTo) && (
                      <span className="absolute -top-1 -right-1 w-3 h-3 bg-primary rounded-full border-2 border-background" />
                    )}
                  </Button>
                </PopoverTrigger>
                <PopoverContent align="end" className="w-80 p-4">
                  <div className="space-y-4">
                    <div className="space-y-1">
                      <h4 className="font-medium leading-none">Filter Records</h4>
                      <p className="text-sm text-muted-foreground">Select a date range to filter.</p>
                    </div>
                    <div className="space-y-3">
                      <DatePicker label="From Date" date={settledDateFrom} setDate={setSettledDateFrom} />
                      <DatePicker label="To Date" date={settledDateTo} setDate={setSettledDateTo} minDate={settledDateFrom} />
                    </div>
                    <div className="flex justify-end pt-2">
                      <Button 
                        variant="ghost" 
                        size="sm" 
                        onClick={() => { setSettledDateFrom(''); setSettledDateTo(''); }}
                        disabled={!settledDateFrom && !settledDateTo}
                      >
                        Clear Filters
                      </Button>
                    </div>
                  </div>
                </PopoverContent>
              </Popover>
              {/* Export CSV moved to Settings modal */}
            </div>
          )}
        </div>
        <div key={activeTab} className="animate-in fade-in slide-in-from-bottom-4 duration-300">
        {activeTab === 'dashboard' && (
          <div className="space-y-6">
            <h2 className="text-2xl font-bold font-serif">Quick Overview</h2>
            <div className="grid grid-cols-2 sm:grid-cols-3 gap-4">
              <Card className="bg-primary/5 border-primary/20">
                <CardHeader className="pb-2">
                  <CardTitle className="text-sm font-medium text-muted-foreground">Active Rentals</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="text-2xl font-bold text-primary">{activeBills.length}</div>
                </CardContent>
              </Card>
              <Card className="bg-amber-500/5 border-amber-500/20">
                <CardHeader className="pb-2">
                  <CardTitle className="text-sm font-medium text-muted-foreground">Pending Bills</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="text-2xl font-bold text-amber-600">{pendingBills.length}</div>
                </CardContent>
              </Card>
              <Card className="bg-blue-500/5 border-blue-500/20">
                <CardHeader className="pb-2">
                  <CardTitle className="text-sm font-medium text-muted-foreground">Upcoming</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="text-2xl font-bold text-blue-600">{upcomingBills.length}</div>
                </CardContent>
              </Card>
              <Card className="bg-emerald-500/5 border-emerald-500/20">
                <CardHeader className="pb-2">
                  <CardTitle className="text-sm font-medium text-muted-foreground">Returns Today</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="text-2xl font-bold text-emerald-600">
                    {bills.filter(b => (getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active') && b.expectedReturnDate === format(new Date(), 'yyyy-MM-dd')).length}
                  </div>
                </CardContent>
              </Card>
              <Card className="bg-indigo-500/5 border-indigo-500/20">
                <CardHeader className="pb-2">
                  <CardTitle className="text-sm font-medium text-muted-foreground">Today's Collections</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="text-2xl font-bold text-indigo-600">₹{dailyTotal.toLocaleString('en-IN')}</div>
                </CardContent>
              </Card>
              <Card className="bg-destructive/5 border-destructive/20">
                <CardHeader className="pb-2">
                  <CardTitle className="text-sm font-medium text-muted-foreground">Total Pending</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="text-2xl font-bold text-destructive">₹{totalPending.toLocaleString('en-IN')}</div>
                </CardContent>
              </Card>
            </div>
            
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <Card>
                <CardHeader className="flex flex-row items-center justify-between pb-2">
                  <CardTitle>Next 7 Days</CardTitle>
                  <CalendarDays className="w-5 h-5 text-muted-foreground" />
                </CardHeader>
                <CardContent>
                  {(() => {
                    const today = new Date();
                    const next7Days = new Date(today);
                    next7Days.setDate(today.getDate() + 7);
                    const todayStr = format(today, 'yyyy-MM-dd');
                    const next7DaysStr = format(next7Days, 'yyyy-MM-dd');

                    const upcoming7DaysBills = bills.filter(b => (getBillDisplayInfo(b).status === 'Upcoming' || getBillDisplayInfo(b).status === 'Partially Active') && b.eventDate && b.eventDate >= todayStr && b.eventDate <= next7DaysStr).sort((a, b) => a.eventDate!.localeCompare(b.eventDate!));
                    const returns7DaysBills = bills.filter(b => (getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active') && b.expectedReturnDate && b.expectedReturnDate >= todayStr && b.expectedReturnDate <= next7DaysStr).sort((a, b) => a.expectedReturnDate!.localeCompare(b.expectedReturnDate!));
                    const payments7DaysBills = bills.filter(b => b.status === 'Pending' && b.paymentPromiseDate && b.paymentPromiseDate >= todayStr && b.paymentPromiseDate <= next7DaysStr).sort((a, b) => a.paymentPromiseDate!.localeCompare(b.paymentPromiseDate!));

                    return (
                      <div className="space-y-4">
                        <div className="grid grid-cols-3 gap-4 border-b border-border pb-4">
                          <div className="text-center cursor-pointer hover:bg-muted/50 p-2 rounded-lg transition-colors" onClick={() => setActiveTab('upcoming')}>
                            <div className="text-2xl font-bold text-blue-500">{upcoming7DaysBills.length}</div>
                            <div className="text-xs text-muted-foreground">Upcoming</div>
                          </div>
                          <div className="text-center cursor-pointer hover:bg-muted/50 p-2 rounded-lg transition-colors" onClick={() => setActiveTab('active')}>
                            <div className="text-2xl font-bold text-amber-500">{returns7DaysBills.length}</div>
                            <div className="text-xs text-muted-foreground">Returns</div>
                          </div>
                          <div className="text-center cursor-pointer hover:bg-muted/50 p-2 rounded-lg transition-colors" onClick={() => setActiveTab('pending')}>
                            <div className="text-2xl font-bold text-orange-500">{payments7DaysBills.length}</div>
                            <div className="text-xs text-muted-foreground">Payments</div>
                          </div>
                        </div>
                        <div className="space-y-3 max-h-[250px] overflow-y-auto custom-scrollbar pr-2">
                          {upcoming7DaysBills.slice(0, 3).map(b => (
                            <div key={`up-${b.id}`} className="flex justify-between items-center bg-blue-500/5 p-2 rounded-md border border-blue-500/10">
                              <div>
                                <p className="font-medium text-sm">{b.customerName}</p>
                                <p className="text-xs text-muted-foreground">Upcoming on {formatToDDMMYYYY(b.eventDate!)}</p>
                              </div>
                              <Badge variant="outline" className={`text-[10px] ${getBillDisplayInfo(b).status === 'Partially Active' ? 'bg-purple-500/10 text-purple-500 border-purple-500/20' : 'bg-blue-500/10 text-blue-500 border-blue-500/20'}`}>{getBillDisplayInfo(b).status}</Badge>
                            </div>
                          ))}
                          {returns7DaysBills.slice(0, 3).map(b => (
                            <div key={`ret-${b.id}`} className="flex justify-between items-center bg-amber-500/5 p-2 rounded-md border border-amber-500/10">
                              <div>
                                <p className="font-medium text-sm">{b.customerName}</p>
                                <p className="text-xs text-muted-foreground">Return by {formatToDDMMYYYY(b.expectedReturnDate!)}</p>
                              </div>
                              <Badge variant="outline" className="text-[10px] bg-amber-500/10 text-amber-500 border-amber-500/20">Return</Badge>
                            </div>
                          ))}
                          {payments7DaysBills.slice(0, 3).map(b => (
                            <div key={`pay-${b.id}`} className="flex justify-between items-center bg-orange-500/5 p-2 rounded-md border border-orange-500/10">
                              <div>
                                <p className="font-medium text-sm">{b.customerName}</p>
                                <p className="text-xs text-muted-foreground">Payment due {formatToDDMMYYYY(b.paymentPromiseDate!)}</p>
                              </div>
                              <Badge variant="outline" className="text-[10px] bg-orange-500/10 text-orange-500 border-orange-500/20">₹{b.totalCost - b.advance}</Badge>
                            </div>
                          ))}
                          {upcoming7DaysBills.length === 0 && returns7DaysBills.length === 0 && payments7DaysBills.length === 0 && (
                            <p className="text-sm text-muted-foreground text-center py-4">No upcoming activities in the next 7 days</p>
                          )}
                        </div>
                      </div>
                    );
                  })()}
                </CardContent>
              </Card>
              
              <Card>
                <CardHeader>
                  <CardTitle>Action Required</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="space-y-4">
                    {bills.filter(b => b.status === 'Pending' && b.paymentPromiseDate && b.paymentPromiseDate <= format(new Date(), 'yyyy-MM-dd')).slice(0, 5).map(b => (
                      <div key={b.id} className="flex justify-between items-center border-b pb-2 last:border-0 last:pb-0">
                        <div>
                          <p className="font-medium">{b.customerName}</p>
                          <p className="text-xs text-destructive">Payment Overdue</p>
                        </div>
                        <div className="text-right">
                          <p className="font-medium text-destructive">₹{(b.totalCost - b.advance).toLocaleString('en-IN')}</p>
                          <Button variant="outline" size="sm" className="h-6 text-[10px] mt-1" onClick={() => { setActiveTab('pending'); }}>View</Button>
                        </div>
                      </div>
                    ))}
                    {bills.filter(b => b.status === 'Pending' && b.paymentPromiseDate && b.paymentPromiseDate <= format(new Date(), 'yyyy-MM-dd')).length === 0 && (
                      <p className="text-sm text-muted-foreground text-center py-4">No urgent actions required</p>
                    )}
                  </div>
                </CardContent>
              </Card>
            </div>

            <Card className="shadow-sm border-border bg-card">
              <CardHeader className="bg-card border-b border-border flex flex-row items-center justify-between">
                <CardTitle className="text-lg text-foreground">Monthly Revenue Trend</CardTitle>
                <BarChart3 className="w-5 h-5 text-muted-foreground" />
              </CardHeader>
              <CardContent className="p-6">
                <ChartContainer config={{ revenue: { label: "Revenue", color: "hsl(var(--primary))" } }} className="h-[300px] w-full">
                  <BarChart data={monthlyRevenueData} margin={{ top: 10, right: 10, left: -20, bottom: 0 }}>
                    <CartesianGrid strokeDasharray="3 3" vertical={false} />
                    <XAxis dataKey="month" tickLine={false} axisLine={false} />
                    <YAxis tickFormatter={(value) => `₹${value >= 1000 ? (value/1000).toFixed(1) + 'k' : value}`} tickLine={false} axisLine={false} />
                    <ChartTooltip content={<ChartTooltipContent indicator="line" />} />
                    <Bar dataKey="revenue" fill="var(--color-revenue)" radius={[4, 4, 0, 0]} animationDuration={1500} />
                  </BarChart>
                </ChartContainer>
              </CardContent>
            </Card>

            <Card className="shadow-sm border-border bg-card">
              <CardHeader className="bg-card border-b border-border flex flex-row items-center justify-between">
                <CardTitle className="text-lg text-foreground">Recent Payments</CardTitle>
                <Button variant="outline" size="sm" onClick={() => setActiveTab('settled')}>View Settled Records</Button>
              </CardHeader>
              <CardContent className="p-0">
                <Table>
                  <TableHeader className="bg-accent/40">
                    <TableRow className="border-border">
                      <TableHead>Date</TableHead>
                      <TableHead>Customer</TableHead>
                      <TableHead>Amount</TableHead>
                      <TableHead className="text-right">Bill ID</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {(() => {
                      const allPayments = bills.flatMap(b => 
                        (b.payments || []).map(p => ({
                          ...p,
                          customerName: b.customerName,
                          billId: b.id
                        }))
                      ).sort((a, b) => b.date.localeCompare(a.date)).slice(0, 10);

                      if (allPayments.length === 0) {
                        return <TableRow><TableCell colSpan={4} className="text-center py-8 text-muted-foreground">No payments recorded yet</TableCell></TableRow>;
                      }

                      return allPayments.map((p, idx) => (
                        <TableRow key={idx} className="border-border">
                          <TableCell className="text-foreground">{formatToDDMMYYYY(p.date)}</TableCell>
                          <TableCell className="font-medium text-foreground">{p.customerName}</TableCell>
                          <TableCell className="text-emerald-600 font-bold">₹{p.amount.toLocaleString('en-IN')}</TableCell>
                          <TableCell className="text-right text-xs text-muted-foreground">{p.billId}</TableCell>
                        </TableRow>
                      ));
                    })()}
                  </TableBody>
                </Table>
              </CardContent>
            </Card>
          </div>
        )}

        {activeTab === 'home' && (
          <div className="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6">
            {/* Left Column: New Bill (Swapped) */}
            <div className="lg:col-span-7 order-first lg:order-first space-y-4">
          {/* Warning Section for Bills Needing Attention */}
          {(() => {
            const today = format(new Date(), 'yyyy-MM-dd');
            const overdueReturns = bills.filter(b => (getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active') && b.expectedReturnDate && b.expectedReturnDate <= today);
            const overduePayments = bills.filter(b => b.status === 'Pending' && b.paymentPromiseDate && b.paymentPromiseDate <= today);
            
            if (overdueReturns.length === 0 && overduePayments.length === 0) return null;

            return (
              <div className="animate-in fade-in slide-in-from-top-4 duration-500">
                <div className="bg-destructive/10 border border-destructive/20 rounded-xl p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 shadow-sm">
                  <div className="flex items-center gap-3">
                    <div className="bg-destructive text-destructive-foreground p-2 rounded-full animate-pulse">
                      <Bell className="w-5 h-5" />
                    </div>
                    <div>
                      <h3 className="font-bold text-destructive text-sm">Action Required</h3>
                      <p className="text-xs text-muted-foreground">
                        {overdueReturns.length > 0 && `${overdueReturns.length} Return(s) due/overdue. `}
                        {overduePayments.length > 0 && `${overduePayments.length} Payment(s) due/overdue.`}
                      </p>
                    </div>
                  </div>
                  <div className="flex gap-2 w-full sm:w-auto">
                    {overdueReturns.length > 0 && (
                      <Button 
                        size="sm" 
                        variant="destructive" 
                        className="flex-1 sm:flex-none text-[11px] h-8"
                        onClick={() => {
                          setActiveTab('active');
                          setSearchTerm('');
                          window.scrollTo({ top: document.getElementById('bottom-dashboards')?.offsetTop || 800, behavior: 'smooth' });
                        }}
                      >
                        Check Returns
                      </Button>
                    )}
                    {overduePayments.length > 0 && (
                      <Button 
                        size="sm" 
                        variant="destructive" 
                        className="flex-1 sm:flex-none text-[11px] h-8"
                        onClick={() => {
                          setActiveTab('pending');
                          setSearchTerm('');
                          window.scrollTo({ top: document.getElementById('bottom-dashboards')?.offsetTop || 800, behavior: 'smooth' });
                        }}
                      >
                        Check Payments
                      </Button>
                    )}
                  </div>
                </div>
              </div>
            );
          })()}



          <Card className="shadow-sm border-border bg-card">
            <CardHeader className="bg-accent/40 border-b border-border rounded-t-xl">
              <CardTitle className="text-xl text-foreground">New Rental Bill</CardTitle>
            </CardHeader>
            <CardContent className="p-6 space-y-6">
<div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div className="space-y-2">
                  <Label>Customer Name *</Label>
                  <Input value={customerName} onChange={e => setCustomerName(e.target.value)} placeholder="e.g. Rajesh Kumar" />
                </div>
                <div className="space-y-2">
                  <Label>Mobile Number *</Label>
                  <Input 
                    type="tel"
                    maxLength={10}
                    value={mobile} 
                    onChange={e => {
                      const val = e.target.value.replace(/\D/g, '');
                      if (val.length <= 10) setMobile(val);
                    }} 
                    placeholder="e.g. 9876543210" 
                  />
                </div>
                <div className="space-y-2">
                  <Label>Customer Address</Label>
                  <Input value={address} onChange={e => setAddress(e.target.value)} placeholder="e.g. Ongole, Andhra Pradesh" />
                </div>
                <div className="space-y-2">
                  <Label>Event / Outward Date</Label>
                  <DatePicker 
                    date={eventDate} 
                    setDate={setEventDate} 
                  />
                </div>
                <div className="space-y-2">
                  <Label>Event Time</Label>
                  <TimePicker time={eventTime} setTime={setEventTime} />
                </div>
                <div className="space-y-2">
                  <Label>Transportation (₹)</Label>
                  <Input type="number" value={transportationCharges ?? ''} onChange={e => setTransportationCharges(e.target.value ? Number(e.target.value) : '')} placeholder="0" />
                </div>
                
                <div className="sm:col-span-2">
                  <Accordion type="single" collapsible className="w-full bg-muted/30 rounded-lg px-4 border border-border">
                    <AccordionItem value="optional-details" className="border-none">
                      <AccordionTrigger className="text-sm font-medium py-3 hover:no-underline">
                        Add Optional Details (Advance, Expected Return, Referral, Notes...)
                      </AccordionTrigger>
                      <AccordionContent>
                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2 pb-4">
                          <div className="space-y-2">
                            <Label>Advance Paid (₹)</Label>
                            <Input type="number" value={advance ?? ''} onChange={e => setAdvance(e.target.value ? Number(e.target.value) : '')} placeholder="0" />
                          </div>

                          <div className="space-y-2">
                            <DatePicker 
                              label="Expected Return" 
                              date={expectedReturnDate} 
                              setDate={setExpectedReturnDate} 
                              minDate={eventDate || format(new Date(), 'yyyy-MM-dd')}
                            />
                          </div>
                          <div className="space-y-2">
                            <Label>Referral</Label>
                            <Input value={referral} onChange={e => setReferral(e.target.value)} placeholder="e.g. Friend, Event Manager" />
                          </div>
                          <div className="space-y-2 sm:col-span-2">
                            <Label>Notes / Special Instructions</Label>
                            <Input value={notes} onChange={e => setNotes(e.target.value)} placeholder="e.g. Deliver to side gate" />
                          </div>
                        </div>
                      </AccordionContent>
                    </AccordionItem>
                  </Accordion>
                </div>
                <div className="space-y-2 sm:col-span-2 pt-2">
                  <p className="text-[10px] text-muted-foreground italic">
                    * If Event Date is in the future, order will be saved as an "Upcoming Order".
                  </p>
                </div>
              </div>

              <div className="border border-border rounded-lg overflow-hidden">
                <Table>
                  <TableHeader className="bg-accent/40">
                    <TableRow className="border-border">
                      <TableHead>Item</TableHead>
                      <TableHead>Daily Rate</TableHead>
                      <TableHead>Qty</TableHead>
                      <TableHead className="w-[80px]"></TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {stagedItems.length === 0 ? (
                      <TableRow className="border-border">
                        <TableCell colSpan={4} className="text-center text-muted-foreground py-6">No items added yet</TableCell>
                      </TableRow>
                    ) : (
                      stagedItems.map(item => (
                        <TableRow key={item.inventoryId} className="border-border">
                          <TableCell className="font-medium text-foreground">{item.name}</TableCell>
                          <TableCell className="text-foreground">₹{item.price}</TableCell>
                          <TableCell className="text-foreground">{item.qty}</TableCell>
                          <TableCell>
                            <Button variant="ghost" size="icon" className="text-destructive hover:text-destructive/90 hover:bg-destructive/10" onClick={() => handleRemoveStaged(item.inventoryId)}>
                              <Trash2 className="w-4 h-4" />
                            </Button>
                          </TableCell>
                        </TableRow>
                      ))
                    )}
                  </TableBody>
                </Table>
              </div>
            </CardContent>
            <CardFooter className="bg-accent/40 border-t border-border p-4 flex justify-end rounded-b-xl">
              <Button onClick={handleCreateBill} className="bg-primary hover:bg-primary/90 text-primary-foreground font-semibold">
                {eventDate > format(new Date(), 'yyyy-MM-dd') ? 'Create Advance Booking' : 'Create Rental Bill'}
              </Button>
            </CardFooter>
          </Card>
        </div>

        {/* Right Column: Inventory (Swapped & Categorized) */}
        <div className="lg:col-span-5 space-y-6 order-last lg:order-last">
          <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
             <div className="flex items-center gap-3">
               <h2 className="text-2xl font-bold text-foreground">Inventory</h2>
             </div>
             <div className="relative w-full sm:w-64">
               <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
               <Input 
                 type="search" 
                 placeholder="Search inventory..." 
                 className="pl-9 bg-card border-border h-10" 
                 value={inventorySearchTerm}
                 onChange={(e) => setInventorySearchTerm(e.target.value)}
               />
             </div>
          </div>
          <div className="space-y-6 max-h-[800px] overflow-y-auto pr-2">
            {filteredInventory.length === 0 ? (
              <div className="text-center py-10 text-muted-foreground bg-muted/20 rounded-xl border border-dashed border-border">
                No items found matching "{inventorySearchTerm}"
              </div>
            ) : Object.entries(
              filteredInventory.reduce((acc, item) => {
                if (!acc[item.category]) acc[item.category] = [];
                acc[item.category].push(item);
                return acc;
              }, {} as Record<string, InventoryItem[]>)
            ).map(([category, items]) => (
              <div key={category} className="space-y-3 mb-6">
                <h3 className="font-semibold text-lg text-primary border-b border-border/50 pb-1 flex items-center gap-2">
                  {getCategoryIcon(category)} {category}
                </h3>
                <div className="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
                  {items.map(item => (
                    <InventoryModernListRow key={item.id} item={item} onAdd={handleStageItem} />
                  ))}
                </div>
              </div>
            ))}
          </div>

        </div>
          </div>
        )}

        {/* Other Tabs */}
        {activeTab !== 'dashboard' && activeTab !== 'home' && (
          <div className="max-w-7xl mx-auto space-y-8">
            <div className="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 bg-card p-4 rounded-xl border border-border shadow-sm">
              <div className="flex items-center space-x-4 flex-1">
                <Search className="w-5 h-5 text-muted-foreground" />
                <Input 
                  placeholder={activeTab === 'settings' ? "Search settings (e.g., Profile, Staff, Theme)..." : "Search by customer name or mobile number..."}
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                  className="border-0 shadow-none focus-visible:ring-0 px-0 flex-1"
                />
              </div>
              {activeTab !== 'settings' && (
                <div className="flex items-center gap-2 border-l border-border pl-4">
                  <Filter className="w-4 h-4 text-muted-foreground hidden sm:block" />
                  <Select value={handedByFilter} onValueChange={setHandedByFilter}>
                    <SelectTrigger className="w-[160px] border-none bg-transparent shadow-none focus:ring-0">
                      <SelectValue placeholder="Handled By" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="all">All Employees</SelectItem>
                      {employees.map(emp => (
                        <SelectItem key={emp.id} value={emp.name}>{emp.name}</SelectItem>
                      ))}
                    </SelectContent>
                  </Select>
                </div>
              )}
            </div>

            {activeTab === 'upcoming' && (
            <Card className="shadow-sm border-border bg-card">
              <CardHeader className="bg-card border-b border-border">
                <CardTitle className="text-lg text-foreground">Upcoming Orders (Advance Bookings)</CardTitle>
              </CardHeader>
              <CardContent className="p-0">
                <Table>
                  <TableHeader className="bg-accent/40">
                    <TableRow className="border-border">
                      <TableHead>Customer</TableHead>
                      <TableHead>Event Date</TableHead>
                      <TableHead>Advance Paid</TableHead>
                      <TableHead>Status</TableHead>
                      <TableHead className="text-right">Actions</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {paginatedUpcomingBills.length === 0 && (
                      <TableRow className="border-border"><TableCell colSpan={5} className="text-center py-4 text-muted-foreground">No upcoming orders found</TableCell></TableRow>
                    )}
                    {paginatedUpcomingBills.map(bill => {
                      const info = getBillDisplayInfo(bill);
                      return (
                      <TableRow key={bill.id} className="border-border">
                        <TableCell>
                          <div className="flex flex-col items-start text-left">
                            <button className="text-primary font-medium hover:underline" onClick={() => { setSelectedBill(bill); setIsInsightsOpen(true); }}>
                              {bill.customerName}
                            </button>
                            <a href={`tel:${bill.mobile}`} className="text-xs text-muted-foreground hover:text-primary hover:underline">
                              {bill.mobile}
                            </a>
                          </div>
                        </TableCell>
                        <TableCell className="text-foreground">
                          {bill.eventDate ? formatToDDMMYYYY(bill.eventDate) : <span className="text-muted-foreground italic">Not set</span>}
                          {bill.eventTime && <div className="text-xs text-muted-foreground">{bill.eventTime}</div>}
                        </TableCell>
                        <TableCell className="text-foreground">₹{bill.advance}</TableCell>
                        <TableCell>
                          <Badge variant="outline" className={info.status === 'Partially Active' ? 'bg-purple-500/10 text-purple-500 border-purple-500/20' : 'bg-blue-500/10 text-blue-500 border-blue-500/20'}>
                            {info.status}
                          </Badge>
                          {info.status === 'Partially Active' && (
                            <div className="text-[10px] text-muted-foreground mt-1 font-medium">
                              {info.dispatchedCount} sent, {info.upcomingCount} remaining
                            </div>
                          )}
                        </TableCell>
                        <TableCell className="text-right">
                          <DropdownMenu>
                            <DropdownMenuTrigger asChild>
                              <Button variant="ghost" size="icon" className="h-8 w-8">
                                <MoreVertical className="w-4 h-4" />
                              </Button>
                            </DropdownMenuTrigger>
                            <DropdownMenuContent align="end" className="w-48 bg-card border-border">
                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsEditOpen(true); }}>
                                <Edit className="w-4 h-4 mr-2" /> Edit Order
                              </DropdownMenuItem>
                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsPaymentOpen(true); }}>
                                <CreditCard className="w-4 h-4 mr-2" /> Add Payment
                              </DropdownMenuItem>
                              {['Admin', 'Manager'].includes(currentUser.role) && (
                                <>
                                  <DropdownMenuSeparator />
                                  <DropdownMenuItem onClick={() => handleCancelOrder(bill.id)} className="text-destructive focus:text-destructive">
                                    <Trash2 className="w-4 h-4 mr-2" /> Cancel Order
                                  </DropdownMenuItem>
                                </>
                              )}
                            </DropdownMenuContent>
                          </DropdownMenu>
                        </TableCell>
                      </TableRow>
                    );
                    })}
                  </TableBody>
                </Table>
                <CustomPagination 
                  currentPage={upcomingPage} 
                  totalItems={upcomingBills.length} 
                  itemsPerPage={itemsPerPage} 
                  onPageChange={setUpcomingPage} 
                  onItemsPerPageChange={setItemsPerPage}
                />
              </CardContent>
            </Card>
            )}

            {activeTab === 'active' && (
            <Card className="shadow-sm border-border bg-card">
              <CardHeader className="bg-card border-b border-border">
                <CardTitle className="text-lg text-foreground">Active Rentals</CardTitle>
              </CardHeader>
              <CardContent className="p-0">
                <Table>
                  <TableHeader className="bg-accent/40">
                    <TableRow className="border-border">
                      <TableHead>Customer</TableHead>
                      <TableHead>Expected Return</TableHead>
                      <TableHead>Advance Paid</TableHead>
                      <TableHead>Status</TableHead>
                      <TableHead className="text-right">Actions</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {paginatedActiveBills.length === 0 && (
                      <TableRow className="border-border"><TableCell colSpan={5} className="text-center py-4 text-muted-foreground">No active bills found</TableCell></TableRow>
                    )}
                    {paginatedActiveBills.map(bill => {
                      const info = getBillDisplayInfo(bill);
                      return (
                      <TableRow key={bill.id} className="border-border">
                        <TableCell>
                          <div className="flex flex-col items-start text-left">
                            <button className="text-primary font-medium hover:underline" onClick={() => { setSelectedBill(bill); setIsInsightsOpen(true); }}>
                              {bill.customerName}
                            </button>
                            <a href={`tel:${bill.mobile}`} className="text-xs text-muted-foreground hover:text-primary hover:underline">
                              {bill.mobile}
                            </a>
                          </div>
                        </TableCell>
                        <TableCell className="text-foreground">
                          {bill.expectedReturnDate ? formatToDDMMYYYY(bill.expectedReturnDate) : <span className="text-muted-foreground italic">Not set</span>}
                        </TableCell>
                        <TableCell className="text-foreground">₹{bill.advance}</TableCell>
                        <TableCell>
                          <Badge variant="outline" className={info.status === 'Partially Active' ? 'bg-purple-500/10 text-purple-500 border-purple-500/20' : 'bg-amber-500/10 text-amber-500 border-amber-500/20'}>
                            {info.status}
                          </Badge>
                          {info.status === 'Partially Active' && (
                            <div className="text-[10px] text-muted-foreground mt-1 font-medium">
                              {info.dispatchedCount} sent, {info.upcomingCount} remaining
                            </div>
                          )}
                        </TableCell>
                        <TableCell className="text-right">
                          <DropdownMenu>
                            <DropdownMenuTrigger asChild>
                              <Button variant="ghost" size="icon" className="h-8 w-8">
                                <MoreVertical className="w-4 h-4" />
                              </Button>
                            </DropdownMenuTrigger>
                            <DropdownMenuContent align="end" className="w-48 bg-card border-border">
                              <DropdownMenuItem onClick={() => handlePrintReceipt(bill)}>
                                <Printer className="w-4 h-4 mr-2" /> Print Receipt
                              </DropdownMenuItem>

                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsEditOpen(true); }}>
                                <Edit className="w-4 h-4 mr-2" /> Edit Bill
                              </DropdownMenuItem>
                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsPaymentOpen(true); }}>
                                <CreditCard className="w-4 h-4 mr-2" /> Add Payment
                              </DropdownMenuItem>
                              <DropdownMenuSeparator />
                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsReturnOpen(true); }} className="font-medium text-emerald-600 focus:text-emerald-700">
                                <CornerDownLeft className="w-4 h-4 mr-2" /> Log Return
                              </DropdownMenuItem>
                            </DropdownMenuContent>
                          </DropdownMenu>
                        </TableCell>
                      </TableRow>
                    );
                    })}
                  </TableBody>
                </Table>
                <CustomPagination 
                  currentPage={activePage} 
                  totalItems={activeBills.length} 
                  itemsPerPage={itemsPerPage} 
                  onPageChange={setActivePage} 
                  onItemsPerPageChange={setItemsPerPage}
                />
              </CardContent>
            </Card>
            )}

            {activeTab === 'pending' && (
            <Card className="shadow-sm border-border bg-card">
              <CardHeader className="bg-card border-b border-border">
                <CardTitle className="text-lg text-foreground">Pending Bills (Items Returned)</CardTitle>
              </CardHeader>
              <CardContent className="p-0">
                <Table>
                  <TableHeader className="bg-accent/40">
                    <TableRow className="border-border">
                      <TableHead>Customer</TableHead>
                      <TableHead>Total Cost</TableHead>
                      <TableHead>Balance Due</TableHead>
                      <TableHead>Promise Date</TableHead>
                      <TableHead>Status</TableHead>
                      <TableHead className="text-right">Actions</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {paginatedPendingBills.length === 0 && (
                      <TableRow className="border-border"><TableCell colSpan={6} className="text-center py-4 text-muted-foreground">No pending bills found</TableCell></TableRow>
                    )}
                    {paginatedPendingBills.map(bill => {
                      const isDue = bill.paymentPromiseDate && bill.paymentPromiseDate <= format(new Date(), 'yyyy-MM-dd');
                      return (
                      <TableRow key={bill.id} className={`border-border ${isDue ? 'bg-destructive/5' : ''}`}>
                        <TableCell>
                          <div className="flex flex-col items-start text-left">
                            <button className="text-primary font-medium hover:underline" onClick={() => { setSelectedBill(bill); setIsInsightsOpen(true); }}>
                              {bill.customerName}
                            </button>
                            <a href={`tel:${bill.mobile}`} className="text-xs text-muted-foreground hover:text-primary hover:underline">
                              {bill.mobile}
                            </a>
                          </div>
                        </TableCell>
                        <TableCell className="text-foreground">₹{bill.totalCost}</TableCell>
                        <TableCell className="font-semibold">
                          {(() => {
                            const bal = bill.totalCost - bill.advance - (bill.discount || 0);
                            return bal < 0 ? <span className="text-emerald-600">Refund ₹{Math.abs(bal)}</span> : <span className="text-destructive">₹{bal}</span>;
                          })()}
                        </TableCell>
                        <TableCell className="text-foreground">
                          {bill.paymentPromiseDate ? (
                            <span className={isDue ? 'text-destructive font-bold' : ''}>{formatToDDMMYYYY(bill.paymentPromiseDate)}</span>
                          ) : <span className="text-muted-foreground italic">Not set</span>}
                        </TableCell>
                        <TableCell><Badge variant="outline" className="bg-orange-500/10 text-orange-500 border-orange-500/20">Pending</Badge></TableCell>
                        <TableCell className="text-right">
                          <DropdownMenu>
                            <DropdownMenuTrigger asChild>
                              <Button variant="ghost" size="icon" className="h-8 w-8">
                                <MoreVertical className="w-4 h-4" />
                              </Button>
                            </DropdownMenuTrigger>
                            <DropdownMenuContent align="end" className="w-48 bg-card border-border">
                              <DropdownMenuItem onClick={() => handlePrintReceipt(bill)}>
                                <Printer className="w-4 h-4 mr-2" /> Print Receipt
                              </DropdownMenuItem>

                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsEditOpen(true); }}>
                                <Edit className="w-4 h-4 mr-2" /> Edit Bill
                              </DropdownMenuItem>
                              <DropdownMenuItem onClick={() => {
                                const pendingAmount = bill.totalCost - bill.advance - (bill.discount || 0);
                                const itemsList = bill.items.map(i => `${i.qtyIssued}x ${i.name}`).join(', ');
                                const message = pendingAmount < 0 
                                  ? `Hello ${bill.customerName},\n\nThis is a message from Padma Suppliers. You have a refund due of ₹${Math.abs(pendingAmount)}.\n\nItems rented:\n${itemsList}\n\nPlease contact us to process your refund. Thank you!`
                                  : `Hello ${bill.customerName},\n\nThis is a reminder from Padma Suppliers. Your pending bill amount is ₹${pendingAmount}.\n\nItems rented:\n${itemsList}\n\nPlease arrange the payment at your earliest convenience. Thank you!`;
                                const waNumber = bill.mobile.length === 10 ? `91${bill.mobile}` : bill.mobile;
                                window.open(`https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`, '_blank');
                              }}>
                                <MessageCircle className="w-4 h-4 mr-2" /> WhatsApp Reminder
                              </DropdownMenuItem>
                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setPromiseDateInput(bill.paymentPromiseDate || ''); setIsPromiseDateOpen(true); }}>
                                <Clock className="w-4 h-4 mr-2" /> Set Due Date
                              </DropdownMenuItem>
                              <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsPaymentOpen(true); }}>
                                <CreditCard className="w-4 h-4 mr-2" /> Add Payment
                              </DropdownMenuItem>
                              <DropdownMenuSeparator />
                              <DropdownMenuItem onClick={() => handleMarkAsPaid(bill.id)} className="font-medium text-emerald-600 focus:text-emerald-700">
                                <CheckCircle2 className="w-4 h-4 mr-2" /> Mark as Paid
                              </DropdownMenuItem>
                            </DropdownMenuContent>
                          </DropdownMenu>
                        </TableCell>
                      </TableRow>
                    )})}
                  </TableBody>
                </Table>
                <CustomPagination 
                  currentPage={pendingPage} 
                  totalItems={pendingBills.length} 
                  itemsPerPage={itemsPerPage} 
                  onPageChange={setPendingPage} 
                  onItemsPerPageChange={setItemsPerPage}
                />
              </CardContent>
            </Card>
            )}

            {activeTab === 'settled' && (
            <div className="space-y-4">

              <Card className="shadow-sm border-border bg-card">
                <CardHeader className="bg-card border-b border-border">
                  <CardTitle className="text-lg text-foreground">Settled Records</CardTitle>
                </CardHeader>
                <CardContent className="p-0">
                  <Table>
                    <TableHeader className="bg-accent/40">
                      <TableRow className="border-border">
                        <TableHead>Customer</TableHead>
                        <TableHead>Final Bill</TableHead>
                        <TableHead>Status</TableHead>
                        <TableHead className="text-right">Actions</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {(() => {
                        if (paginatedSettledBills.length === 0) {
                          return (
                            <TableRow className="border-border">
                              <TableCell colSpan={4} className="text-center py-4 text-muted-foreground">
                                No settled bills found
                              </TableCell>
                            </TableRow>
                          );
                        }

                        return paginatedSettledBills.map(bill => (
                          <TableRow key={bill.id} className="border-border">
                            <TableCell>
                              <div className="flex flex-col items-start text-left">
                                <button className="text-primary font-medium hover:underline" onClick={() => { setSelectedBill(bill); setIsInsightsOpen(true); }}>
                                  {bill.customerName}
                                </button>
                                <a href={`tel:${bill.mobile}`} className="text-xs text-muted-foreground hover:text-primary hover:underline">
                                  {bill.mobile}
                                </a>
                              </div>
                            </TableCell>
                            <TableCell className="text-foreground">₹{Math.max(0, bill.totalCost - (bill.discount || 0))}</TableCell>
                            <TableCell><Badge variant="outline" className="bg-emerald-500/10 text-emerald-500 border-emerald-500/20">Paid</Badge></TableCell>
                            <TableCell className="text-right">
                              <DropdownMenu>
                                <DropdownMenuTrigger asChild>
                                  <Button variant="ghost" size="icon" className="h-8 w-8">
                                    <MoreVertical className="w-4 h-4" />
                                  </Button>
                                </DropdownMenuTrigger>
                                <DropdownMenuContent align="end" className="w-48 bg-card border-border">
                                  <DropdownMenuItem onClick={() => handlePrintReceipt(bill)}>
                                    <Printer className="w-4 h-4 mr-2" /> Print Receipt
                                  </DropdownMenuItem>

                                  <DropdownMenuItem onClick={() => { setSelectedBill(bill); setIsInsightsOpen(true); }}>
                                    <Eye className="w-4 h-4 mr-2" /> View Details
                                  </DropdownMenuItem>
                                </DropdownMenuContent>
                              </DropdownMenu>
                            </TableCell>
                          </TableRow>
                        ));
                      })()}
                    </TableBody>
                  </Table>
                  <CustomPagination 
                    currentPage={settledPage} 
                    totalItems={settledRecordsBills.length} 
                    itemsPerPage={itemsPerPage} 
                    onPageChange={setSettledPage} 
                    onItemsPerPageChange={setItemsPerPage}
                  />
                </CardContent>
              </Card>
            </div>
            )}

            {activeTab === 'calendar' && (
            <Card className="shadow-sm border-border bg-card">
              <CardHeader className="bg-card border-b border-border">
                <CardTitle className="text-lg text-foreground">Return Calendar</CardTitle>
              </CardHeader>
              <CardContent className="p-6 flex flex-col md:flex-row gap-8 items-start">
                <div className="flex-shrink-0 flex justify-center md:justify-start">
                  <Calendar
                    mode="single"
                    selected={selectedDate}
                    onSelect={setSelectedDate}
                    modifiers={{ 
                      alert: [
                        ...bills.filter(b => (getBillDisplayInfo(b).status === 'Upcoming' || getBillDisplayInfo(b).status === 'Partially Active') && b.eventDate).map(b => parseDateLocal(b.eventDate!)),
                        ...bills.filter(b => b.status === 'Pending' && b.paymentPromiseDate).map(b => parseDateLocal(b.paymentPromiseDate!))
                      ]
                    }}
                    modifiersStyles={{ 
                      alert: { fontWeight: 'bold', border: '2px solid hsl(var(--destructive))', borderRadius: '100%' }
                    }}
                    className="rounded-md border border-border bg-card shadow-sm"
                  />
                </div>
                <div className="flex-1 space-y-6">
                   <div className="flex flex-col sm:flex-row items-center justify-between gap-4">
                     <h3 className="font-semibold text-lg text-foreground">
                       Schedule for {selectedDate ? format(selectedDate, 'dd MMM yyyy') : '...'}
                     </h3>
                     <Select value={calendarFilter} onValueChange={setCalendarFilter}>
                       <SelectTrigger className="w-[180px] bg-card border-border">
                         <SelectValue placeholder="Filter by status" />
                       </SelectTrigger>
                       <SelectContent className="bg-card border-border">
                         <SelectItem value="all">All Activities</SelectItem>
                         <SelectItem value="Upcoming">Upcoming Orders</SelectItem>
                         <SelectItem value="Active">Active Rentals</SelectItem>
                         <SelectItem value="Pending">Pending Bills</SelectItem>
                         <SelectItem value="Paid">Settled Records</SelectItem>
                       </SelectContent>
                     </Select>
                   </div>

                   {(() => {
                     if (displayBills.length === 0) {
                       return (
                         <div className="text-center py-10 bg-muted/10 rounded-xl border border-dashed border-border">
                           <p className="text-muted-foreground">No records found for this date and filter.</p>
                         </div>
                       );
                     }

                     return (
                       <div className="space-y-4">
                         {displayBills.map(bill => (
                           <Card key={bill.id} className="p-4 border-border shadow-sm bg-card hover:bg-muted/10 transition-colors">
                             <div className="flex justify-between items-start">
                               <div>
                                 <div className="flex items-center gap-2">
                                   <h4 className="font-medium text-primary cursor-pointer hover:underline" onClick={() => { setSelectedBill(bill); setIsInsightsOpen(true); }}>
                                     {bill.customerName}
                                   </h4>
                                   <Badge variant="outline" className={`text-[10px] h-4 ${
                                     bill.status === 'Paid' ? 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20' :
                                     bill.status === 'Pending' ? 'bg-orange-500/10 text-orange-500 border-orange-500/20' :
                                     bill.status === 'Active' ? 'bg-amber-500/10 text-amber-500 border-amber-500/20' :
                                     'bg-blue-500/10 text-blue-500 border-blue-500/20'
                                   }`}>
                                     {bill.status}
                                   </Badge>
                                 </div>
                                 <a href={`tel:${bill.mobile}`} className="text-xs text-muted-foreground hover:text-primary hover:underline">
                                   {bill.mobile}
                                 </a>
                               </div>
                               <div className="text-right">
                                 <p className="text-xs font-bold">₹{bill.totalCost - (bill.discount || 0)}</p>
                                 <p className="text-[10px] text-muted-foreground">{bill.id}</p>
                               </div>
                             </div>
                             <div className="mt-2 text-xs text-foreground bg-muted/30 p-2 rounded flex flex-col gap-1">
                               {bill.items.map(i => {
                                 const isSent = i.issueDate <= format(new Date(), 'yyyy-MM-dd');
                                 return (
                                   <div key={i.id} className="flex justify-between items-center border-b border-border/50 last:border-0 pb-1 last:pb-0">
                                     <span>{i.qtyIssued}x {i.name}</span>
                                     <span className={`text-[10px] font-medium ${isSent ? "text-emerald-600" : "text-blue-600"}`}>{isSent ? "Sent" : "Upcoming"}</span>
                                   </div>
                                 );
                               })}
                             </div>
                             <div className="mt-3 flex justify-end gap-2">
                               <Button size="sm" variant="outline" className="h-7 text-[10px]" onClick={() => handlePrintReceipt(bill)}>
                                 <Printer className="w-3 h-3 mr-1" /> Print
                               </Button>

                               {bill.status === 'Active' && bill.expectedReturnDate === calendarDateStr && (
                                 <Button size="sm" variant="outline" className="h-7 text-[10px] bg-destructive/10 text-destructive border-destructive/20 hover:bg-destructive/20" onClick={() => { setSelectedBill(bill); setIsReturnOpen(true); }}>
                                   <CornerDownLeft className="w-3 h-3 mr-1" /> Log Return
                                 </Button>
                               )}
                               {bill.status === 'Pending' && bill.paymentPromiseDate === calendarDateStr && (
                                 <Button size="sm" variant="outline" className="h-7 text-[10px] bg-emerald-600/10 text-emerald-600 border-emerald-600/20 hover:bg-emerald-600/20" onClick={() => { setSelectedBill(bill); setIsPaymentOpen(true); }}>
                                   <CreditCard className="w-3 h-3 mr-1" /> Add Payment
                                 </Button>
                               )}
                               {bill.status === 'Pending' && bill.paymentPromiseDate === calendarDateStr && (
                                 <Button size="sm" variant="default" className="h-7 text-[10px] bg-emerald-600 hover:bg-emerald-700 text-white" onClick={() => handleMarkAsPaid(bill.id)}>
                                   <CheckCircle2 className="w-3 h-3 mr-1" /> Paid
                                 </Button>
                               )}
                             </div>
                           </Card>
                         ))}
                       </div>
                     );
                   })()}
                </div>
              </CardContent>
            </Card>
            )}

          </div>
        )}
      {/* Settings View */}
      {activeTab === 'settings' && (
        <div className="bg-card border border-border rounded-xl min-h-[600px] flex flex-col overflow-hidden mt-2">
          <div className="flex-1 overflow-hidden flex">
            <Tabs value={activeSettingsTab} onValueChange={setActiveSettingsTab} className="w-full h-full flex flex-col sm:flex-row" orientation="vertical">
              <div className="sm:w-48 shrink-0 border-b sm:border-b-0 sm:border-r border-border bg-muted/10 overflow-x-auto sm:overflow-y-auto">
                <TabsList className="flex sm:flex-col h-auto w-max sm:w-full justify-start items-start p-2 gap-1 bg-transparent">
                  {(!searchTerm || 'profile'.includes(searchTerm.toLowerCase())) && <TabsTrigger value="profile" className="w-full justify-start text-left data-[state=active]:bg-primary/10 data-[state=active]:text-primary data-[state=active]:shadow-none">Profile</TabsTrigger>}
                  {(!searchTerm || 'general'.includes(searchTerm.toLowerCase()) || 'theme'.includes(searchTerm.toLowerCase()) || 'receipt'.includes(searchTerm.toLowerCase()) || 'dark'.includes(searchTerm.toLowerCase()) || 'mode'.includes(searchTerm.toLowerCase())) && <TabsTrigger value="general" className="w-full justify-start text-left data-[state=active]:bg-primary/10 data-[state=active]:text-primary data-[state=active]:shadow-none">General</TabsTrigger>}
                  {(!searchTerm || 'staff'.includes(searchTerm.toLowerCase())) && (currentUser?.role === 'Admin' ? <TabsTrigger value="staff" className="w-full justify-start text-left data-[state=active]:bg-primary/10 data-[state=active]:text-primary data-[state=active]:shadow-none">Staff</TabsTrigger> : <TabsTrigger value="staff" disabled className="w-full justify-start text-left hidden">Staff</TabsTrigger>)}
                  {(!searchTerm || 'inventory'.includes(searchTerm.toLowerCase())) && (currentUser && ['Admin', 'Manager'].includes(currentUser.role) ? <TabsTrigger value="inventory" className="w-full justify-start text-left data-[state=active]:bg-primary/10 data-[state=active]:text-primary data-[state=active]:shadow-none">Inventory</TabsTrigger> : <TabsTrigger value="inventory" disabled className="w-full justify-start text-left hidden">Inventory</TabsTrigger>)}
                  {(!searchTerm || 'export'.includes(searchTerm.toLowerCase()) || 'download'.includes(searchTerm.toLowerCase())) && (currentUser && ['Admin', 'Manager'].includes(currentUser.role) ? <TabsTrigger value="export" className="w-full justify-start text-left data-[state=active]:bg-primary/10 data-[state=active]:text-primary data-[state=active]:shadow-none">Export / Download</TabsTrigger> : <TabsTrigger value="export" disabled className="w-full justify-start text-left hidden">Export / Download</TabsTrigger>)}
                  {(!searchTerm || 'notifications'.includes(searchTerm.toLowerCase()) || 'sound'.includes(searchTerm.toLowerCase())) && <TabsTrigger value="notifications" className="w-full justify-start text-left data-[state=active]:bg-primary/10 data-[state=active]:text-primary data-[state=active]:shadow-none">Notifications</TabsTrigger>}
                  {(!searchTerm || 'database'.includes(searchTerm.toLowerCase())) && (currentUser?.role === 'Admin' ? <TabsTrigger value="database" className="w-full justify-start text-left data-[state=active]:bg-primary/10 data-[state=active]:text-primary data-[state=active]:shadow-none">Database</TabsTrigger> : <TabsTrigger value="database" disabled className="w-full justify-start text-left hidden">Database</TabsTrigger>)}
                </TabsList>
              </div>
              
              <div className="flex-1 overflow-y-auto p-6 relative">
                <TabsContent value="profile" className="space-y-6 mt-0">
                  <div className="space-y-4">
                    <div className="space-y-1 mb-4">
                      <Label className="text-sm font-semibold flex items-center gap-2">
                        <UserCircle className="w-4 h-4 text-muted-foreground" /> Edit Profile
                      </Label>
                      <p className="text-[11px] text-muted-foreground">Manage your account details and PIN</p>
                    </div>
                    
                    <div className="space-y-4 max-w-sm">
                      <div className="space-y-2">
                        <Label>Name</Label>
                        <Input 
                          value={profileEditName} 
                          onChange={e => setProfileEditName(e.target.value)} 
                        />
                      </div>
                      <div className="space-y-2">
                        <Label>Mobile Number</Label>
                        <Input 
                          value={profileEditMobile} 
                          onChange={e => setProfileEditMobile(e.target.value)} 
                        />
                      </div>
                      <Button onClick={handleUpdateProfile} className="w-full">Update Profile</Button>
                      
                      <div className="my-4 border-b border-border"></div>
                      
                      <div className="space-y-2">
                        <Label className="text-sm font-semibold">Change PIN</Label>
                        <Button variant="outline" className="w-full" onClick={() => setIsChangePinOpen(true)}>
                          <Lock className="w-4 h-4 mr-2" /> Change PIN
                        </Button>
                      </div>
                    </div>
                  </div>
                </TabsContent>

                <TabsContent value="general" className="space-y-6 mt-0">
                <div className="space-y-4">
                  <div className="space-y-3">
                    <Label className="text-sm font-semibold flex items-center gap-2">
                      <Printer className="w-4 h-4 text-muted-foreground" /> Receipt Template
                    </Label>
                    <div className="grid grid-cols-2 gap-3">
                      <Button variant={receiptTemplate === 'standard' ? 'default' : 'outline'} className="h-12" onClick={() => setReceiptTemplate('standard')}>
                        Standard A4
                      </Button>
                      <Button variant={receiptTemplate === 'dmart' ? 'default' : 'outline'} className="h-12" onClick={() => setReceiptTemplate('dmart')}>
                        Thermal POS
                      </Button>
                    </div>
                  </div>

                  {receiptTemplate === 'dmart' && (
                    <div className="space-y-3 pt-2 animate-in fade-in slide-in-from-top-2">
                      <Label className="text-sm font-semibold text-muted-foreground">Thermal Paper Size</Label>
                      <div className="grid grid-cols-3 gap-2">
                        <Button variant={thermalSize === '112mm' ? 'default' : 'outline'} size="sm" onClick={() => setThermalSize('112mm')}>112mm</Button>
                        <Button variant={thermalSize === '80mm' ? 'default' : 'outline'} size="sm" onClick={() => setThermalSize('80mm')}>80mm</Button>
                        <Button variant={thermalSize === '58mm' ? 'default' : 'outline'} size="sm" onClick={() => setThermalSize('58mm')}>58mm</Button>
                      </div>
                    </div>
                  )}
                </div>

                <div className="pt-4 border-t border-border flex items-center justify-between">
                  <div className="space-y-1">
                    <Label className="text-sm font-semibold flex items-center gap-2">
                      {theme === 'dark' ? <Moon className="w-4 h-4 text-muted-foreground" /> : <Sun className="w-4 h-4 text-muted-foreground" />} Dark Mode
                    </Label>
                    <p className="text-[11px] text-muted-foreground">Switch between light and dark themes</p>
                  </div>
                  <Switch checked={theme === 'dark'} onCheckedChange={(checked) => setTheme(checked ? 'dark' : 'light')} />
                </div>

                <div className="pt-4 border-t border-border flex items-center justify-between">
                  <div className="space-y-1">
                    <Label className="text-sm font-semibold flex items-center gap-2">
                      <LayoutTemplate className="w-4 h-4 text-muted-foreground" /> Compact Table View
                    </Label>
                    <p className="text-[11px] text-muted-foreground">Reduce padding in tables to see more data at once</p>
                  </div>
                  <Switch checked={isCompactView} onCheckedChange={setIsCompactView} />
                </div>

                <div className="pt-4 border-t border-border space-y-3">
                  <Label className="text-sm font-semibold flex items-center gap-2">
                    <Palette className="w-4 h-4 text-muted-foreground" /> Color Theme
                  </Label>
                  <div className="flex gap-3">
                    {[
                      { id: 'theme-purple', color: 'bg-[#8b5cf6]' },
                      { id: 'theme-blue', color: 'bg-[#3b82f6]' },
                      { id: 'theme-green', color: 'bg-[#22c55e]' },
                      { id: 'theme-orange', color: 'bg-[#f97316]' },
                      { id: 'theme-rose', color: 'bg-[#f43f5e]' },
                    ].map((t) => (
                      <button
                        key={t.id}
                        onClick={() => setColorTheme(t.id)}
                        className={`w-8 h-8 rounded-full ${t.color} ${colorTheme === t.id ? 'ring-2 ring-offset-2 ring-foreground ring-offset-background' : 'hover:scale-110 transition-transform'}`}
                        title={t.id.replace('theme-', '')}
                      />
                    ))}
                  </div>
                </div>

                </TabsContent>

                <TabsContent value="notifications" className="space-y-6 mt-0">
                  <div className="space-y-4">
                    <div className="space-y-1 mb-4">
                      <Label className="text-sm font-semibold flex items-center gap-2">
                        <Bell className="w-4 h-4 text-muted-foreground" /> Notifications
                      </Label>
                      <p className="text-[11px] text-muted-foreground">Customize your notification preferences</p>
                    </div>

                    <div className="space-y-3">
                      <Label className="text-sm font-semibold flex items-center gap-2">
                        <Speaker className="w-4 h-4 text-muted-foreground" /> Notification Sound
                      </Label>
                      <Select 
                        value={notificationSound} 
                        onValueChange={(val: any) => {
                          setNotificationSound(val);
                          import('@/lib/sounds').then(m => m.playNotificationSound(val));
                        }}
                      >
                        <SelectTrigger className="w-full">
                          <SelectValue placeholder="Select sound" />
                        </SelectTrigger>
                        <SelectContent>
                          <SelectItem value="none">None (Mute)</SelectItem>
                          <SelectItem value="pop">Pop (Default)</SelectItem>
                          <SelectItem value="water_drop">Water Drop</SelectItem>
                          <SelectItem value="bell">Bell</SelectItem>
                        </SelectContent>
                      </Select>
                    </div>

                    <div className="space-y-3 pt-2">
                      <div className="flex items-center justify-between p-3 border border-border rounded-lg bg-muted/30">
                        <div className="space-y-0.5">
                          <Label className="text-sm font-semibold flex items-center gap-2">
                            <Bell className="w-4 h-4 text-muted-foreground" /> Browser Push Notifications
                          </Label>
                          <p className="text-[11px] text-muted-foreground">Receive alerts on your device even when the app is minimized</p>
                        </div>
                        <Switch 
                          checked={pushEnabled} 
                          onCheckedChange={async (checked) => {
                            if (!("Notification" in window)) {
                              toast.error("Push notifications not supported by your browser");
                              return;
                            }
                            if (checked) {
                              const permission = await Notification.requestPermission();
                              if (permission === "granted") {
                                setPushEnabled(true);
                                new Notification("Padma Suppliers POS", {
                                  body: "Push notifications enabled successfully!",
                                  icon: "https://assets.cdn.filesafe.space/9YKSM9vJJwAmtxbBkIyB/media/6a136179fe2210f89e688b6d.png"
                                });
                                toast.success("Push notifications enabled");
                              } else {
                                setPushEnabled(false);
                                toast.error("Permission denied for push notifications");
                              }
                            } else {
                              setPushEnabled(false);
                              toast.success("Push notifications disabled (Browser level permissions may still be active)");
                            }
                          }}
                        />
                      </div>
                    </div>
                  </div>
                </TabsContent>

              {currentUser?.role === 'Admin' && (
                <TabsContent value="staff" className="space-y-4 mt-0">
                  <div className="flex items-center justify-between mb-4">
                    <Label className="text-sm font-semibold flex items-center gap-2">
                      <Users className="w-4 h-4 text-muted-foreground" /> Staff Management
                    </Label>
                    {!isAddingEmployee && (
                      <Button size="sm" onClick={() => setIsAddingEmployee(true)}>
                        <Plus className="w-4 h-4 mr-2" /> Add Employee
                      </Button>
                    )}
                  </div>
                  
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-3 max-h-[300px] overflow-y-auto pr-1 custom-scrollbar">
                  {employees.map((emp: any) => (
                    <Card key={emp.id} className="overflow-hidden border-border/50 hover:border-primary/50 transition-colors shadow-sm">
                      <div className="p-3 flex items-center justify-between">
                        <div className="flex items-center gap-3">
                          <div className="h-10 w-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-lg border border-primary/20">
                            {emp.name.charAt(0).toUpperCase()}
                          </div>
                          <div>
                            <div className="font-medium flex items-center gap-2 text-sm">
                              {emp.name}
                              <Badge variant={emp.role === 'Admin' ? 'default' : emp.role === 'Manager' ? 'secondary' : 'outline'} className="text-[10px] h-4 px-1">
                                {emp.role}
                              </Badge>
                            </div>
                            <div className="text-xs text-muted-foreground flex items-center gap-1 mt-0.5">
                              <UserCircle className="w-3 h-3" /> {emp.mobile}
                            </div>
                          </div>
                        </div>
                        
                        {emp.role !== 'Admin' && (
                          <Button variant="ghost" size="icon" className="text-destructive hover:text-destructive hover:bg-destructive/10 h-8 w-8" onClick={async () => {
                            if (supabase) {
                              await supabase.from('employees').delete().eq('id', emp.id);
                            }
                            setEmployees(employees.filter((e: any) => e.id !== emp.id));
                          }}>
                            <Trash2 className="w-4 h-4" />
                          </Button>
                        )}
                      </div>
                    </Card>
                  ))}
                </div>
                  {isAddingEmployee && (
                    <div className="flex flex-col gap-3 pt-4 border-t border-border mt-4 animate-in fade-in slide-in-from-top-2">
                      <h4 className="text-xs font-bold uppercase text-muted-foreground mb-1">New Employee Details</h4>
                      <div className="grid grid-cols-2 gap-3">
                        <div className="space-y-1.5">
                          <Label className="text-[11px]">Name</Label>
                          <Input value={newEmpName} onChange={e => setNewEmpName(e.target.value)} placeholder="e.g. Suresh" className="h-9 text-sm" />
                        </div>
                        <div className="space-y-1.5">
                          <Label className="text-[11px]">Mobile (10 digits)</Label>
                          <Input value={newEmpMobile} onChange={e => setNewEmpMobile(e.target.value)} placeholder="9876543210" maxLength={10} className="h-9 text-sm" />
                        </div>
                      </div>
                      <div className="grid grid-cols-2 gap-3 items-end">
                        <div className="space-y-1.5">
                          <Label className="text-[11px]">Role</Label>
                        <Select value={newEmpRole} onValueChange={setNewEmpRole}>
                          <SelectTrigger className="h-9 text-sm"><SelectValue /></SelectTrigger>
                          <SelectContent>
                            <SelectItem value="Admin">Admin</SelectItem>
                            <SelectItem value="Manager">Manager</SelectItem>
                            <SelectItem value="Staff">Staff</SelectItem>
                          </SelectContent>
                        </Select>
                      </div>
                        <div className="flex gap-2">
                          <Button size="sm" variant="ghost" className="h-9 flex-1" onClick={() => setIsAddingEmployee(false)}>Cancel</Button>
                          <Button size="sm" className="h-9 flex-1" onClick={async () => {
                          if (!newEmpName || newEmpMobile.length !== 10) {
                            toast.error("Enter name and 10-digit mobile number");
                            return;
                          }
                          const initialPin = newEmpMobile.substring(0, 4);
                          const newEmp = { id: crypto.randomUUID(), name: newEmpName, mobile: newEmpMobile, role: newEmpRole, pin: initialPin };
                          
                          if (supabase) {
                            const { error } = await supabase.from('employees').insert([newEmp]);
                            if (error) {
                              console.error("Supabase insert error:", error);
                              toast.error("Failed to add staff: " + error.message);
                              return;
                            }
                          }

                          setEmployees([...employees, newEmp]);
                          setNewEmpName('');
                          setNewEmpMobile('');
                          setNewEmpRole('Staff');
                          setIsAddingEmployee(false);
                          toast.success(`Staff added! Initial PIN: ${initialPin}`);
                        }}>
                          Save
                        </Button>
                      </div>
                    </div>
                  </div>
                )}
                </TabsContent>
              )}

              {currentUser && ['Admin', 'Manager'].includes(currentUser.role) && (
                <TabsContent value="inventory" className="space-y-4 mt-0">
                  <div className="space-y-3">
                    <Label className="text-sm font-semibold flex items-center gap-2">
                      <Package className="w-4 h-4 text-muted-foreground" /> Inventory Management
                    </Label>
                    <p className="text-[11px] text-muted-foreground mb-4">
                      Update your product catalog, categories, and pricing.
                    </p>
                    <Button 
                      className="w-full h-12 bg-primary/10 text-primary hover:bg-primary/20 border-primary/20"
                      variant="outline"
                      onClick={() => { setIsInventoryManageOpen(true); }}
                    >
                      <Edit className="w-4 h-4 mr-2" /> Open Bulk Edit Inventory
                    </Button>
                  </div>
                </TabsContent>
              )}
              {currentUser && ['Admin', 'Manager'].includes(currentUser.role) && (
                <TabsContent value="export" className="space-y-4 mt-0">
                  <div className="space-y-1 mb-4">
                    <Label className="text-sm font-semibold flex items-center gap-2">
                      <Download className="w-4 h-4 text-muted-foreground" /> Export Data
                    </Label>
                    <p className="text-[11px] text-muted-foreground">Download your records as CSV files</p>
                  </div>
                  <div className="space-y-4">
                    <div className="space-y-2">
                      <Label className="text-xs font-bold uppercase text-muted-foreground">Monthly Settled Report</Label>
                      <div className="flex gap-2">
                        <Input type="month" value={exportMonth} onChange={e => setExportMonth(e.target.value)} className="flex-1" />
                        <Button onClick={handleExportCSV} variant="outline">Download</Button>
                      </div>
                    </div>
                    <div className="space-y-2">
                      <Label className="text-xs font-bold uppercase text-muted-foreground">Full Business Backup</Label>
                      <Button onClick={handleExportAllCSV} className="bg-primary hover:bg-primary/90 text-primary-foreground w-full">
                        <Download className="w-4 h-4 mr-2" /> Download Full CSV
                      </Button>
                    </div>
                  </div>
                </TabsContent>
              )}

              {currentUser?.role === 'Admin' && (
                <TabsContent value="database" className="space-y-6 mt-0">
                  <div className="space-y-4">
                    <Label className="text-sm font-semibold flex items-center gap-2">
                      <Database className="w-4 h-4 text-muted-foreground" /> Database Maintenance
                    </Label>
                    
                    <div className="p-4 bg-muted/30 rounded-xl border border-border space-y-3">
                      <div className="flex items-center justify-between">
                        <div className="flex items-center gap-2">
                          <div className={`w-2 h-2 rounded-full ${supabase ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]' : 'bg-destructive shadow-[0_0_8px_rgba(239,68,68,0.5)]'}`} />
                          <span className="text-sm font-medium">Cloud Connection</span>
                        </div>
                        <Badge variant={supabase ? 'default' : 'destructive'} className={supabase ? 'bg-emerald-500/10 text-emerald-600 hover:bg-emerald-500/20' : ''}>
                          {supabase ? 'Active' : 'Offline'}
                        </Badge>
                      </div>
                      <p className="text-[11px] text-muted-foreground">
                        Status of the connection to your Supabase cloud database.
                      </p>
                    </div>

                    <div className="pt-2">
                      <Button 
                        variant="outline" 
                        className="w-full border-destructive/30 text-destructive hover:bg-destructive/5 hover:text-destructive h-10"
                        onClick={() => setShowSqlDialog(true)}
                      >
                        <Wrench className="w-4 h-4 mr-2" /> Show Database Repair SQL
                      </Button>
                      <p className="text-[10px] text-muted-foreground leading-relaxed mt-2 text-center">
                        If sync is failing, run the repair SQL in your Supabase dashboard to fix missing columns or permissions.
                      </p>
                    </div>
                  </div>
                </TabsContent>
              )}
              </div>
            </Tabs>
          </div>
        </div>
      )}
        </div>
      </main>
    </div>
  </div>

  {/* MODALS */}
      <AlertDialog open={isWarningOpen} onOpenChange={setIsWarningOpen}>
        <AlertDialogContent className="bg-card border-border">
          <AlertDialogHeader>
            <AlertDialogTitle className="text-foreground">Missing Optional Details</AlertDialogTitle>
            <AlertDialogDescription className="text-muted-foreground">
              You are dispatching items today but left the following fields empty:
              <ul className="list-disc pl-5 mt-2 space-y-1 font-medium text-foreground">
                {warningMessage.map(field => <li key={field}>{field}</li>)}
              </ul>
              <br/>
              Do you want to proceed anyway?
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel>Cancel</AlertDialogCancel>
            <AlertDialogAction onClick={() => { setIsWarningOpen(false); proceedCreateBill(); }} className="bg-primary hover:bg-primary/90 text-primary-foreground">
              Proceed Anyway
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>

      {selectedBill && (
        <>
          {/* Customer Insights Modal */}
          <Dialog open={isInsightsOpen} onOpenChange={setIsInsightsOpen}>
            <DialogContent className="w-[95vw] sm:w-full max-w-2xl max-h-[80vh] overflow-y-auto bg-card border-border">
              <DialogHeader>
                <DialogTitle className="text-foreground">Customer Insights: {selectedBill.customerName}</DialogTitle>
              </DialogHeader>
              <div className="space-y-4">
                <div className="grid grid-cols-2 gap-4 text-sm text-foreground">
                  <div><span className="text-muted-foreground">Mobile:</span> <a href={`tel:${selectedBill.mobile}`} className="hover:text-primary hover:underline">{selectedBill.mobile}</a></div>
                  <div><span className="text-muted-foreground">Referral:</span> {selectedBill.referral || 'N/A'}</div>
                  <div className="flex items-center gap-2">
                    <span className="text-muted-foreground">Status:</span> {selectedBill.status}
                    <Button variant="link" size="sm" className="h-auto p-0 text-primary" onClick={() => { setHistoryMobile(selectedBill.mobile); setIsHistoryOpen(true); }}>
                      View Full History
                    </Button>
                  </div>
                  {selectedBill.eventDate && <div><span className="text-muted-foreground">Event Date:</span> {formatToDDMMYYYY(selectedBill.eventDate)} {selectedBill.eventTime && `at ${selectedBill.eventTime}`}</div>}
                  <div><span className="text-muted-foreground">Total Cost:</span> ₹{selectedBill.totalCost}</div>
                  {selectedBill.transportationCharges ? (
                    <div><span className="text-muted-foreground">Transportation Cost:</span> ₹{selectedBill.transportationCharges}</div>
                  ) : null}
                  {selectedBill.damageCharges ? (
                    <div><span className="text-muted-foreground">Damages:</span> ₹{selectedBill.damageCharges}</div>
                  ) : null}
                  {selectedBill.discount > 0 && <div><span className="text-muted-foreground">Discount:</span> ₹{selectedBill.discount}</div>}
                  {(() => {
                    const bal = selectedBill.totalCost - selectedBill.advance - (selectedBill.discount || 0);
                    return bal < 0 
                      ? <div><span className="text-muted-foreground">Refund Due:</span> <span className="text-emerald-600 font-bold">₹{Math.abs(bal)}</span></div>
                      : <div><span className="text-muted-foreground">Balance:</span> ₹{bal}</div>;
                  })()}
                  <div className="col-span-2 flex items-center justify-between text-xs text-muted-foreground mt-2 border-t border-border pt-3">
                    <div>
                      Created by: <span className="font-medium text-foreground">{selectedBill.createdBy || 'Admin'}</span>
                    </div>
                    <Button variant="outline" size="sm" onClick={() => { setNotesInput(selectedBill.notes || ''); setIsNotesOpen(true); }}>
                      <FileText className="w-4 h-4 mr-1" /> View / Edit Notes
                    </Button>
                  </div>
                </div>

                <div>
                  <h4 className="font-semibold text-foreground mb-2">Current Items Status</h4>
                  <Table>
                    <TableHeader className="bg-muted/50">
                      <TableRow className="border-border">
                        <TableHead>Item</TableHead>
                        <TableHead>Status</TableHead>
                        <TableHead>Issued</TableHead>
                        <TableHead>Returned</TableHead>
                        <TableHead>Missing</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {selectedBill.items.map(item => {
                        const missing = item.qtyIssued - item.qtyReturned;
                        const todayStr = format(new Date(), 'yyyy-MM-dd');
                        const isSent = item.issueDate <= todayStr;
                        return (
                          <TableRow key={item.id} className="border-border">
                            <TableCell className="text-foreground">
                              {item.name}
                              <div className="text-[10px] text-muted-foreground mt-1">Date: {formatToDDMMYYYY(item.issueDate)}</div>
                            </TableCell>
                            <TableCell>
                              {isSent ? (
                                <div className="flex flex-col gap-1 items-start">
                                  <Badge variant="outline" className="bg-emerald-500/10 text-emerald-500 border-emerald-500/20 text-[10px]">Sent</Badge>
                                  <span className="text-[9px] text-muted-foreground whitespace-nowrap">By: {item.handledBy || selectedBill.createdBy || 'Admin'}</span>
                                </div>
                              ) : (
                                <Badge variant="outline" className="bg-blue-500/10 text-blue-500 border-blue-500/20 text-[10px]">Upcoming</Badge>
                              )}
                            </TableCell>
                            <TableCell className="text-foreground">{item.qtyIssued}</TableCell>
                            <TableCell className="text-foreground">{item.qtyReturned}</TableCell>
                            <TableCell className={missing > 0 ? "text-destructive font-bold" : "text-emerald-500"}>
                              {missing}
                            </TableCell>
                          </TableRow>
                        );
                      })}
                    </TableBody>
                  </Table>
                </div>

                {selectedBill.returnHistory.length > 0 && (
                  <div>
                    <h4 className="font-semibold text-foreground mb-2 mt-4">Return Log History</h4>
                    <div className="space-y-3">
                      {selectedBill.returnHistory.map((log, idx) => (
                        <Card key={idx} className="border-border shadow-sm bg-card">
                          <CardHeader className="bg-muted/50 p-3 pb-2 border-b border-border flex flex-row justify-between items-center">
                            <div className="text-sm font-medium text-foreground">Return Date: {log.date}</div>
                            <Badge variant="outline" className="text-[10px] font-normal">Handled by: {log.handledBy || 'Admin'}</Badge>
                          </CardHeader>
                          <CardContent className="p-3">
                            <ul className="text-sm space-y-1 text-foreground">
                              {log.items.map((item, i) => (
                                <li key={i} className="flex justify-between">
                                  <span>{item.qty}x {item.name} ({item.days} days)</span>
                                  <span className="font-medium">₹{item.cost}</span>
                                </li>
                              ))}
                            </ul>
                          </CardContent>
                        </Card>
                      ))}
                    </div>
                  </div>
                )}

                {selectedBill.payments && selectedBill.payments.length > 0 && (
                  <div>
                    <h4 className="font-semibold text-foreground mb-2 mt-4">Payment History</h4>
                    <div className="space-y-2">
                      {selectedBill.payments.map((p, idx) => (
                        <div key={idx} className="flex justify-between text-sm border-b border-border pb-1">
                          <div className="flex flex-col">
                            <span>{formatToDDMMYYYY(p.date)}</span>
                            <span className="text-[10px] text-muted-foreground">Received by: {p.handledBy || 'Admin'}</span>
                          </div>
                          <span className="font-medium text-emerald-600">+ ₹{p.amount}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                <div>
                  <h4 className="font-semibold text-foreground mb-4 mt-6">Order Timeline</h4>
                  <div className="relative border-l-2 border-border ml-3 space-y-6">
                    {getTimelineEvents(selectedBill).map((ev, idx) => (
                      <div key={idx} className="relative pl-6">
                        <div className={cn(
                          "absolute -left-[9px] top-1 w-4 h-4 rounded-full border-2 border-card",
                          ev.type === 'created' ? 'bg-blue-500' :
                          ev.type === 'sent' ? 'bg-emerald-500' :
                          ev.type === 'returned' ? 'bg-purple-500' :
                          ev.type === 'payment' ? 'bg-green-500' :
                          ev.type === 'discount' ? 'bg-yellow-500' :
                          ev.type === 'charge' ? 'bg-red-500' :
                          'bg-amber-500'
                        )} />
                        <div className="flex flex-col">
                          <span className="text-xs font-semibold text-muted-foreground">{formatToDDMMYYYY(ev.date)}</span>
                          <span className="text-sm font-medium text-foreground">{ev.description}</span>
                          {ev.details && <span className="text-xs text-muted-foreground mt-1">
                            {ev.details}
                            {ev.balanceUpdate && <span className="text-foreground font-semibold ml-1">{ev.balanceUpdate}</span>}
                          </span>}
                          {ev.handledBy && <span className="text-[10px] text-muted-foreground mt-1">Handled by: {ev.handledBy}</span>}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
                
                <div className="flex flex-col sm:flex-row gap-2 mt-6 pt-4 border-t border-border">
                  <Button variant="outline" className="flex-1" onClick={() => handlePrintReceipt(selectedBill)}>
                    <Printer className="w-4 h-4 mr-2" /> Print Receipt
                  </Button>

                </div>
              </div>
            </DialogContent>
          </Dialog>

          {/* Edit Bill Modal */}
          <Dialog open={isEditOpen} onOpenChange={setIsEditOpen}>
            <DialogContent className="w-[95vw] sm:w-full max-w-2xl max-h-[80vh] overflow-y-auto bg-card border-border">
              <DialogHeader>
                <DialogTitle className="text-foreground">Edit Bill: {selectedBill.customerName}</DialogTitle>
              </DialogHeader>
<div className="space-y-6">
                <div className="border-b border-border pb-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
                  <div className="space-y-2">
                    <Label>Advance Paid (₹)</Label>
                    <Input 
                      type="number" 
                      value={selectedBill.advance ?? ''} 
                      onChange={e => {
                        const val = e.target.value === '' ? '' : Number(e.target.value);
                        const updated = { ...selectedBill, advance: val as any };
                        setSelectedBill(updated);
                        setBills(prev => prev.map(b => b.id === updated.id ? updated : b));
                      }} 
                    />
                  </div>
                  <div className="space-y-2">
                    <Label>Transportation Cost (₹)</Label>
                    <Input 
                      type="number" 
                      value={selectedBill.transportationCharges ?? ''} 
                      onChange={e => {
                        const val = e.target.value === '' ? '' : Number(e.target.value);
                        const oldVal = Number(selectedBill.transportationCharges) || 0;
                        const numVal = Number(val) || 0;
                        const updated = { 
                          ...selectedBill, 
                          transportationCharges: val as any,
                          totalCost: Number(selectedBill.totalCost) - oldVal + numVal
                        };
                        setSelectedBill(updated);
                        setBills(prev => prev.map(b => b.id === updated.id ? updated : b));
                      }} 
                    />
                  </div>
                  <div className="space-y-2">
                    <Label>Global Discount (₹)</Label>
                    <Input 
                      type="number" 
                      value={selectedBill.discount ?? ''} 
                      disabled={!['Admin', 'Manager'].includes(currentUser.role)}
                      onChange={e => {
                        const val = e.target.value === '' ? '' : Number(e.target.value);
                        const updated = { ...selectedBill, discount: val as any };
                        setSelectedBill(updated);
                        setBills(prev => prev.map(b => b.id === updated.id ? updated : b));
                      }} 
                    />
                  </div>
                  <div className="space-y-2 sm:col-span-3">
                    <Label>Notes / Special Instructions</Label>
                    <Input 
                      value={selectedBill.notes ?? ''} 
                      onChange={e => {
                        const updated = { ...selectedBill, notes: e.target.value };
                        setSelectedBill(updated);
                        setBills(prev => prev.map(b => b.id === updated.id ? updated : b));
                      }} 
                    />
                  </div>
                </div>
                <div>
                  <h4 className="font-semibold text-foreground mb-2">Current Items</h4>
                  <Table>
                    <TableHeader className="bg-muted/50">
                      <TableRow className="border-border">
                        <TableHead>Item</TableHead>
                        <TableHead>Issued</TableHead>
                        <TableHead>Returned</TableHead>
                        <TableHead></TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {selectedBill.items.map(item => {
                        const todayStr = format(new Date(), 'yyyy-MM-dd');
                        const isSent = item.issueDate <= todayStr;
                        return (
                        <TableRow key={item.id} className="border-border">
                          <TableCell className="text-foreground">
                            {item.name}
                            <div className="text-[10px] text-muted-foreground flex items-center gap-2 mt-1">
                              <span>Date: {formatToDDMMYYYY(item.issueDate)}</span>
                              <span className={isSent ? "text-emerald-500" : "text-blue-500"}>{isSent ? "(Sent)" : "(Upcoming)"}</span>
                              {isSent && <span className="text-muted-foreground ml-1 border-l border-border pl-2">By: {item.handledBy || selectedBill.createdBy || 'Admin'}</span>}
                            </div>
                          </TableCell>
                          <TableCell className="text-foreground">{item.qtyIssued}</TableCell>
                          <TableCell className="text-foreground">{item.qtyReturned}</TableCell>
                          <TableCell className="text-right">
                            {['Admin', 'Manager'].includes(currentUser.role) && item.qtyReturned === 0 && (
                              <Button variant="ghost" size="sm" className="text-destructive hover:text-destructive/90 hover:bg-destructive/10" onClick={() => handleDeleteItem(selectedBill.id, item.id)}>
                                <Trash2 className="w-4 h-4" />
                              </Button>
                            )}
                            {item.qtyIssued > 1 && item.qtyReturned === 0 && (
                              <Button variant="outline" size="sm" className="ml-2 h-7 px-2 text-[10px]" onClick={() => {
                                setSplitItemId(item.id);
                                setSplitQty(1);
                                setSplitDate(format(new Date(), 'yyyy-MM-dd'));
                              }}>
                                Split
                              </Button>
                            )}
                            {!isSent && (
                              <Button variant="outline" size="sm" className="ml-2 h-7 px-2 text-[10px] bg-emerald-500/10 text-emerald-600 border-emerald-500/20 hover:bg-emerald-500/20" onClick={() => handleSendItem(selectedBill.id, item.id)}>
                                Send
                              </Button>
                            )}
                          </TableCell>
                        </TableRow>
                        );
                      })}
                    </TableBody>
                  </Table>
                </div>
                
                <div className="border-t border-border pt-4">
                  <h4 className="font-semibold text-foreground mb-4">Add New Item</h4>
                  <AddNewItemForm inventory={inventory} onAdd={handleAddNewItemToBill} />
                </div>
              </div>
            </DialogContent>
          </Dialog>

          {/* Split Item Modal */}
          <Dialog open={!!splitItemId} onOpenChange={(open) => !open && setSplitItemId(null)}>
            <DialogContent className="w-[95vw] sm:w-full max-w-sm bg-card border-border">
              <DialogHeader>
                <DialogTitle className="text-foreground">Split / Partial Dispatch</DialogTitle>
              </DialogHeader>
              <div className="space-y-4 py-4">
                <div className="space-y-2">
                  <Label>Quantity to Split</Label>
                  <Input 
                    type="number" 
                    min="1" 
                    max={selectedBill?.items.find(i => i.id === splitItemId)?.qtyIssued ? selectedBill.items.find(i => i.id === splitItemId)!.qtyIssued - 1 : 1} 
                    value={splitQty} 
                    onChange={e => setSplitQty(Number(e.target.value))} 
                  />
                  <p className="text-[10px] text-muted-foreground">
                    This will separate {splitQty || 0} items into a new batch with a different date.
                  </p>
                </div>
                <DatePicker 
                  label="New Issue / Dispatch Date" 
                  date={splitDate} 
                  setDate={setSplitDate} 
                />
              </div>
              <DialogFooter>
                <Button onClick={handleSplitItem} className="bg-primary hover:bg-primary/90 text-primary-foreground w-full">
                  Confirm Split
                </Button>
              </DialogFooter>
            </DialogContent>
          </Dialog>



          {/* Log Return Modal */}
          <Dialog open={isReturnOpen} onOpenChange={setIsReturnOpen}>
            <DialogContent className="w-[95vw] sm:w-full max-w-xl max-h-[80vh] overflow-y-auto bg-card border-border">
              <DialogHeader>
                <DialogTitle className="text-foreground">Log Return for {selectedBill.customerName}</DialogTitle>
              </DialogHeader>
              <LogReturnForm bill={selectedBill} userRole={currentUser.role} onLog={handleLogReturn} />
            </DialogContent>
          </Dialog>

          {/* Promise Date Modal */}
          <Dialog open={isPromiseDateOpen} onOpenChange={setIsPromiseDateOpen}>
            <DialogContent className="w-[95vw] sm:w-full max-w-sm bg-card border-border">
              <DialogHeader>
                <DialogTitle className="text-foreground">Set Payment Promise Date</DialogTitle>
              </DialogHeader>
              <div className="space-y-4 py-4">
                <DatePicker 
                  label="Promise Date" 
                  date={promiseDateInput} 
                  setDate={setPromiseDateInput} 
                  minDate={format(new Date(), 'yyyy-MM-dd')}
                />
              </div>
              <DialogFooter>
                <Button onClick={() => {
                  if (!selectedBill) return;
                  const updatedBill = { ...selectedBill, paymentPromiseDate: promiseDateInput };
                  const updatedBills = bills.map(b => b.id === updatedBill.id ? updatedBill : b);
                  setBills(updatedBills);
                  syncToCloud('SET_PROMISE_DATE', updatedBill, updatedBills);
                  setIsPromiseDateOpen(false);
                }} className="bg-primary hover:bg-primary/90 text-primary-foreground w-full">
                  Save Date
                </Button>
              </DialogFooter>
            </DialogContent>
          </Dialog>


          {/* Partial Payment Modal */}
          <Dialog open={isPaymentOpen} onOpenChange={setIsPaymentOpen}>
            <DialogContent className="w-[95vw] sm:w-full max-w-sm bg-card border-border">
              <DialogHeader>
                <DialogTitle className="text-foreground">Add Partial Payment</DialogTitle>
              </DialogHeader>
              <div className="space-y-4 py-4">
                <DatePicker 
                  label="Date" 
                  date={paymentDate} 
                  setDate={setPaymentDate} 
                  maxDate={format(new Date(), 'yyyy-MM-dd')}
                />
                <div className="space-y-2">
                  <Label>Amount (₹)</Label>
                  <Input type="number" value={paymentAmount} onChange={e => setPaymentAmount(e.target.value)} placeholder="0" />
                </div>
                <div className="space-y-2">
                  <Label>Apply Discount (₹)</Label>
                  <Input type="number" value={paymentDiscount} disabled={!['Admin', 'Manager'].includes(currentUser.role)} onChange={e => setPaymentDiscount(e.target.value)} placeholder="0" />
                  <p className="text-[10px] text-muted-foreground">Current Discount: ₹{selectedBill.discount || 0}</p>
                </div>
              </div>
              <DialogFooter>
                <Button onClick={handleAddPayment} className="bg-primary hover:bg-primary/90 text-primary-foreground w-full">
                  Save Payment
                </Button>
              </DialogFooter>
            </DialogContent>
          </Dialog>

          {/* Notes Modal */}
          <Dialog open={isNotesOpen} onOpenChange={setIsNotesOpen}>
            <DialogContent className="w-[95vw] sm:w-full max-w-md bg-card border-border">
              <DialogHeader>
                <DialogTitle className="text-foreground">Notes for {selectedBill.customerName}</DialogTitle>
              </DialogHeader>
              <div className="py-4">
                <Textarea 
                  value={notesInput} 
                  onChange={e => setNotesInput(e.target.value)} 
                  placeholder="Enter special instructions or notes here..."
                  className="min-h-[150px] resize-none"
                />
              </div>
              <DialogFooter>
                <Button variant="outline" onClick={() => setIsNotesOpen(false)}>Cancel</Button>
                <Button onClick={() => {
                  if (!selectedBill) return;
                  const updatedBill = { ...selectedBill, notes: notesInput };
                  const updatedBills = bills.map(b => b.id === updatedBill.id ? updatedBill : b);
                  setBills(updatedBills);
                  setSelectedBill(updatedBill);
                  syncToCloud('UPDATE_NOTES', updatedBill, updatedBills);
                  setIsNotesOpen(false);
                }} className="bg-primary hover:bg-primary/90 text-primary-foreground">
                  Save Notes
                </Button>
              </DialogFooter>
            </DialogContent>
          </Dialog>
        </>
      )}

      {/* Change PIN Modal */}
      <Dialog open={isChangePinOpen} onOpenChange={setIsChangePinOpen}>
        <DialogContent className="w-[95vw] sm:w-full max-w-sm bg-card border-border">
          <DialogHeader>
            <DialogTitle className="text-foreground">Change PIN</DialogTitle>
          </DialogHeader>
          <div className="space-y-4 py-4">
            <div className="space-y-2">
              <Label>Current PIN</Label>
              <Input 
                type="password" 
                inputMode="numeric"
                maxLength={4} 
                value={currentPinInput} 
                onChange={e => setCurrentPinInput(e.target.value)}
                placeholder="****" 
              />
            </div>
            <div className="space-y-2">
              <Label>New PIN</Label>
              <Input 
                type="password" 
                inputMode="numeric"
                maxLength={4} 
                value={newPinInput} 
                onChange={e => setNewPinInput(e.target.value)}
                placeholder="****" 
              />
            </div>
            <div className="space-y-2">
              <Label>Confirm New PIN</Label>
              <Input 
                type="password" 
                inputMode="numeric"
                maxLength={4} 
                value={confirmPinInput} 
                onChange={e => setConfirmPinInput(e.target.value)}
                placeholder="****" 
              />
            </div>
          </div>
          <DialogFooter>
            <Button onClick={async () => {
              const user = employees.find((e: any) => e.id === currentUser?.id);
              if (!user) return;
              
              let actualPin = user.pin;
              if (supabase) {
                const { data } = await supabase.from('employees').select('pin').eq('id', user.id).single();
                if (data) actualPin = data.pin;
              }

              if (actualPin !== currentPinInput) {
                toast.error("Current PIN is incorrect");
                return;
              }
              if (newPinInput.length !== 4) {
                toast.error("New PIN must be exactly 4 digits");
                return;
              }
              if (newPinInput !== confirmPinInput) {
                toast.error("New PINs do not match");
                return;
              }

              if (supabase) {
                const { error } = await supabase.from('employees').update({ pin: newPinInput }).eq('id', user.id);
                if (error) {
                  toast.error("Failed to update PIN in database");
                  return;
                }
              }

              const updatedEmployees = employees.map((e: any) => e.id === currentUser.id ? { ...e, pin: newPinInput } : e);
              setEmployees(updatedEmployees);
              toast.success("PIN changed successfully");
              setIsChangePinOpen(false);
              setCurrentPinInput('');
              setNewPinInput('');
              setConfirmPinInput('');
            }} className="bg-primary hover:bg-primary/90 text-primary-foreground w-full">
              Update PIN
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Customer History Modal */}
      <Dialog open={isHistoryOpen} onOpenChange={setIsHistoryOpen}>
        <DialogContent className="w-[95vw] sm:w-full max-w-4xl max-h-[85vh] overflow-y-auto bg-card border-border">
          <DialogHeader>
            <DialogTitle className="text-foreground flex items-center gap-2">
              <RefreshCw className="w-5 h-5 text-primary" />
              Rental History for {bills.find(b => b.mobile === historyMobile)?.customerName || historyMobile}
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              {(() => {
                const customerBills = bills.filter(b => b.mobile === historyMobile);
                const totalSpent = customerBills.reduce((sum, b) => sum + (b.totalCost - (b.discount || 0)), 0);
                const activeRentals = customerBills.filter(b => getBillDisplayInfo(b).status === 'Active' || getBillDisplayInfo(b).status === 'Partially Active').length;
                const totalOrders = customerBills.length;
                
                return (
                  <>
                    <Card className="bg-primary/5 border-primary/10 p-4">
                      <div className="text-xs text-muted-foreground uppercase font-bold">Total Business</div>
                      <div className="text-2xl font-bold text-primary">₹{totalSpent}</div>
                    </Card>
                    <Card className="bg-amber-500/5 border-amber-500/10 p-4">
                      <div className="text-xs text-muted-foreground uppercase font-bold">Active Rentals</div>
                      <div className="text-2xl font-bold text-amber-600">{activeRentals}</div>
                    </Card>
                    <Card className="bg-muted/30 border-border p-4">
                      <div className="text-xs text-muted-foreground uppercase font-bold">Total Orders</div>
                      <div className="text-2xl font-bold text-foreground">{totalOrders}</div>
                    </Card>
                  </>
                );
              })()}
            </div>

            <div className="border border-border rounded-xl overflow-hidden">
              <Table>
                <TableHeader className="bg-muted/50">
                  <TableRow className="border-border">
                    <TableHead>Bill ID</TableHead>
                    <TableHead>Date</TableHead>
                    <TableHead>Items</TableHead>
                    <TableHead>Total</TableHead>
                    <TableHead>Status</TableHead>
                    <TableHead></TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {bills.filter(b => b.mobile === historyMobile).sort((a, b) => b.id.localeCompare(a.id)).map(bill => (
                    <TableRow key={bill.id} className="border-border">
                      <TableCell className="text-xs font-mono">{bill.id}</TableCell>
                      <TableCell className="text-sm">{bill.eventDate ? formatToDDMMYYYY(bill.eventDate) : 'N/A'}</TableCell>
                      <TableCell className="max-w-[200px] text-xs text-muted-foreground">
                        <div className="flex flex-col gap-1 max-h-24 overflow-y-auto">
                          {bill.items.map(i => (
                            <div key={i.id} className="flex justify-between border-b border-border/20 last:border-0 pb-1">
                              <span>{i.qtyIssued}x {i.name}</span>
                              <span className={i.issueDate <= format(new Date(), 'yyyy-MM-dd') ? "text-emerald-500" : "text-blue-500"}>
                                {i.issueDate <= format(new Date(), 'yyyy-MM-dd') ? 'Sent' : 'Upcoming'}
                              </span>
                            </div>
                          ))}
                        </div>
                      </TableCell>
                      <TableCell className="font-bold">₹{bill.totalCost - (bill.discount || 0)}</TableCell>
                      <TableCell>
                        <Badge variant="outline" className={
                          bill.status === 'Paid' ? 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20' :
                          bill.status === 'Pending' ? 'bg-orange-500/10 text-orange-500 border-orange-500/20' :
                          bill.status === 'Active' ? 'bg-amber-500/10 text-amber-500 border-amber-500/20' :
                          'bg-blue-500/10 text-blue-500 border-blue-500/20'
                        }>
                          {bill.status}
                        </Badge>
                      </TableCell>
                      <TableCell>
                        <Button variant="ghost" size="sm" onClick={() => { setSelectedBill(bill); setIsInsightsOpen(true); }}>
                          <Eye className="w-4 h-4" />
                        </Button>
                      </TableCell>
                    </TableRow>
                  ))}
                </TableBody>
              </Table>
            </div>
          </div>
        </DialogContent>
      </Dialog>

      {/* Export Modal */}

      {/* Inventory Management Modal */}
      <Dialog open={isInventoryManageOpen} onOpenChange={setIsInventoryManageOpen}>
        <DialogContent className="w-[95vw] sm:w-full max-w-4xl max-h-[85vh] overflow-y-auto bg-card border-border">
          <DialogHeader>
            <DialogTitle className="text-foreground">Bulk Edit Inventory</DialogTitle>
          </DialogHeader>
          <div className="space-y-4 py-4">
            <Button variant="outline" className="w-full border-dashed" onClick={() => {
              setEditingInventory([{ id: `INV-${Date.now()}`, name: '', category: 'Furniture', price: 0 }, ...editingInventory]);
            }}>
              <Plus className="w-4 h-4 mr-2" /> Add New Item
            </Button>
            <div className="border border-border rounded-xl overflow-hidden">
              <Table>
                <TableHeader className="bg-muted/50">
                  <TableRow className="border-border">
                    <TableHead>Item Name</TableHead>
                    <TableHead>Category</TableHead>
                    <TableHead className="w-[120px]">Daily Rate (₹)</TableHead>
                    <TableHead className="w-[60px]"></TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {editingInventory.map((item, index) => (
                    <TableRow key={item.id} className="border-border">
                      <TableCell>
                        <Input 
                          value={item.name} 
                          onChange={e => {
                            const newInv = [...editingInventory];
                            newInv[index] = { ...newInv[index], name: e.target.value };
                            setEditingInventory(newInv);
                          }} 
                          className="h-8"
                        />
                      </TableCell>
                      <TableCell>
                        <Input 
                          value={item.category} 
                          onChange={e => {
                            const newInv = [...editingInventory];
                            newInv[index] = { ...newInv[index], category: e.target.value };
                            setEditingInventory(newInv);
                          }} 
                          list="categories"
                          className="h-8"
                        />
                      </TableCell>
                      <TableCell>
                        <Input 
                          type="number"
                          value={item.price === 0 ? '' : item.price} 
                          onChange={e => {
                            const newInv = [...editingInventory];
                            newInv[index] = { ...newInv[index], price: e.target.value === '' ? 0 : Number(e.target.value) };
                            setEditingInventory(newInv);
                          }} 
                          className="h-8"
                        />
                      </TableCell>
                      <TableCell>
                        <Button variant="ghost" size="sm" className="text-destructive h-8 w-8 p-0" onClick={() => {
                          setEditingInventory(editingInventory.filter((_, i) => i !== index));
                        }}>
                          <Trash2 className="w-4 h-4" />
                        </Button>
                      </TableCell>
                    </TableRow>
                  ))}
                </TableBody>
              </Table>
            </div>
            <datalist id="categories">
              <option value="Tents & Canopies" />
              <option value="Furniture" />
              <option value="Lighting & Electrical" />
              <option value="Decor & Linens" />
              <option value="Structures" />
              <option value="Cooling & Heating" />
              <option value="Audio/Visual" />
            </datalist>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setIsInventoryManageOpen(false)}>Cancel</Button>
            <Button onClick={async () => {
              setInventory(editingInventory);
              setIsInventoryManageOpen(false);
              toast.success("Inventory updated successfully");
              await syncInventoryToSupabase(editingInventory);
            }} className="bg-primary hover:bg-primary/90 text-primary-foreground">Save Changes</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>




      {/* SQL Repair Dialog */}
      <Dialog open={showSqlDialog} onOpenChange={setShowSqlDialog}>
        <DialogContent className="w-[95vw] sm:w-full max-w-xl bg-card border-border max-h-[90vh] overflow-y-auto">
          <DialogHeader>
            <DialogTitle className="text-foreground">Database Repair Tool</DialogTitle>
          </DialogHeader>
          <div className="space-y-4 py-4">
            {lastSyncError && (
              <div className="p-3 bg-destructive/10 border border-destructive/20 rounded-lg mb-2">
                <p className="text-[10px] font-bold text-destructive uppercase tracking-wider mb-1">Detected Issue:</p>
                <p className="text-xs text-foreground font-medium">{lastSyncError}</p>
              </div>
            )}
            
            <Tabs defaultValue="repair" className="w-full">
              <TabsList className="grid w-full grid-cols-2 mb-4">
                <TabsTrigger value="repair">Standard Repair</TabsTrigger>
                <TabsTrigger value="reset" className="text-destructive">Factory Reset</TabsTrigger>
              </TabsList>
              
              <TabsContent value="repair" className="space-y-4">
                <p className="text-xs text-muted-foreground">
                  Use this to fix missing columns or permissions <b>without deleting your data</b>.
                </p>
                <div className="bg-muted p-4 rounded-lg overflow-x-auto">
                  <pre className="text-[10px] text-foreground font-mono leading-relaxed">
{`-- Ensure all columns exist
ALTER TABLE bills ADD COLUMN IF NOT EXISTS customer_name TEXT;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS mobile TEXT;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS status TEXT;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS advance NUMERIC DEFAULT 0;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS total_cost NUMERIC DEFAULT 0;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS event_date DATE;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS expected_return_date DATE;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS items JSONB DEFAULT '[]'::jsonb;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS return_history JSONB DEFAULT '[]'::jsonb;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS updated_at TIMESTAMP WITH TIME ZONE;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS address TEXT;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS referral TEXT;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS discount NUMERIC DEFAULT 0;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS damage_charges NUMERIC DEFAULT 0;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS transportation_charges NUMERIC DEFAULT 0;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS event_time TEXT;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS payment_promise_date DATE;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS payments JSONB DEFAULT '[]'::jsonb;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS created_by TEXT;
ALTER TABLE bills ADD COLUMN IF NOT EXISTS notes TEXT;

-- Fix Permissions
ALTER TABLE bills ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "Enable all access for all users" ON bills;
CREATE POLICY "Enable all access for all users" ON bills FOR ALL USING (true) WITH CHECK (true);

-- Create Employees Table
CREATE TABLE IF NOT EXISTS employees (
  id TEXT PRIMARY KEY,
  name TEXT NOT NULL,
  mobile TEXT,
  role TEXT NOT NULL,
  pin TEXT NOT NULL
);
ALTER TABLE employees ADD COLUMN IF NOT EXISTS mobile TEXT;
ALTER TABLE employees ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "Enable all access for employees" ON employees;
CREATE POLICY "Enable all access for employees" ON employees FOR ALL USING (true) WITH CHECK (true);

-- Create Inventory Table
CREATE TABLE IF NOT EXISTS inventory (
  id TEXT PRIMARY KEY,
  name TEXT NOT NULL,
  category TEXT NOT NULL,
  price NUMERIC DEFAULT 0
);
ALTER TABLE inventory ENABLE ROW LEVEL SECURITY;
DROP POLICY IF EXISTS "Enable all access for inventory" ON inventory;
CREATE POLICY "Enable all access for inventory" ON inventory FOR ALL USING (true) WITH CHECK (true);`}
                  </pre>
                </div>
                <Button className="w-full" onClick={() => {
                  navigator.clipboard.writeText(`ALTER TABLE bills ADD COLUMN IF NOT EXISTS customer_name TEXT;
